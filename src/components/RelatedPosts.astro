---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import GenerativeHero from './GenerativeHero.astro';

interface Props {
	currentId: string;
	tags: string[];
	category?: string;
	limit?: number;
}

const { currentId, tags, category, limit = 6 } = Astro.props;

const TAG_WEIGHT = 3;
const CATEGORY_WEIGHT = 1;
const RECENCY_HALF_LIFE_DAYS = 60;
const MAX_RECENCY_BONUS = 0.9;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const candidates = allPosts.filter((p) => p.id !== currentId);

const now = Date.now();

function recencyBonus(post: CollectionEntry<'blog'>) {
	const ageDays = Math.max(0, (now - post.data.pubDate.getTime()) / (1000 * 60 * 60 * 24));
	return MAX_RECENCY_BONUS * Math.exp(-ageDays / RECENCY_HALF_LIFE_DAYS);
}

const scored = candidates
	.map((post) => {
		const sharedTags = post.data.tags.filter((t) => tags.includes(t)).length;
		const sameCategory = category && post.data.category === category ? 1 : 0;
		const baseScore = sharedTags * TAG_WEIGHT + sameCategory * CATEGORY_WEIGHT;
		const score = baseScore > 0 ? baseScore + recencyBonus(post) : 0;
		return { post, score };
	})
	.filter((s) => s.score > 0)
	.sort(
		(a, b) =>
			b.score - a.score || b.post.data.pubDate.getTime() - a.post.data.pubDate.getTime(),
	);

const picks: CollectionEntry<'blog'>[] = scored.slice(0, limit).map((s) => s.post);

if (picks.length < limit) {
	const pickedIds = new Set(picks.map((p) => p.id));
	const sameCategoryFallback = candidates
		.filter((p) => !pickedIds.has(p.id) && category && p.data.category === category)
		.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
	for (const post of sameCategoryFallback) {
		if (picks.length >= limit) break;
		picks.push(post);
		pickedIds.add(post.id);
	}

	if (picks.length < limit) {
		const latestFallback = candidates
			.filter((p) => !pickedIds.has(p.id))
			.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
		for (const post of latestFallback) {
			if (picks.length >= limit) break;
			picks.push(post);
		}
	}
}

const relatedPosts = picks;
---

{
	relatedPosts.length > 0 && (
		<section class="related-posts">
			<h2>あわせて読みたい</h2>
			<div class="related-grid">
				{relatedPosts.map((post) => (
					<a href={`/blog/${post.id}/`} class="related-card">
						<div class="related-thumb">
							<GenerativeHero seed={post.data.title} alt={post.data.title} loading="lazy" />
						</div>
						<div class="related-info">
							<span class="related-date">
								<FormattedDate date={post.data.pubDate} />
							</span>
							<h3>{post.data.title}</h3>
						</div>
					</a>
				))}
			</div>
		</section>
	)
}

<style>
	.related-posts {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid var(--color-border);
	}

	.related-posts h2 {
		font-size: 1.25rem;
		margin-bottom: 1.25rem;
	}

	.related-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.related-card {
		text-decoration: none;
		color: inherit;
		background: var(--color-bg-card);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		overflow: hidden;
		transition: transform 0.2s, border-color 0.2s;
	}

	.related-card:hover {
		transform: translateY(-2px);
		border-color: var(--color-primary-light);
		text-decoration: none;
	}

	.related-thumb {
		aspect-ratio: 1200 / 630;
		overflow: hidden;
	}

	.related-thumb :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.related-info {
		padding: 0.75rem;
	}

	.related-date {
		font-size: 0.75rem;
		color: var(--color-text-muted);
	}

	.related-info h3 {
		font-size: 0.85rem;
		line-height: 1.5;
		margin-top: 0.25rem;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	@media (max-width: 900px) {
		.related-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.related-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
