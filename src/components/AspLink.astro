---
/**
 * ASP アフィリエイトリンク（SaaS 無料トライアル誘導等）
 *
 * 使い方:
 *   <AspLink
 *     name="Claude Pro"
 *     url="https://example.com/trial"
 *     description="月額$20でClaude 3.5が使い放題"
 *     cta="無料で試してみる"
 *   />
 *
 *   <AspLink
 *     name="Cursor"
 *     url="https://example.com/cursor"
 *     description="AIエディタの決定版。無料プランあり"
 *     cta="Cursorを試す"
 *     badge="無料プランあり"
 *   />
 */
interface Props {
	/** サービス名 */
	name: string;
	/** アフィリエイトリンクURL */
	url: string;
	/** サービスの一行説明 */
	description?: string;
	/** CTAボタンのテキスト */
	cta?: string;
	/** バッジ（「無料プランあり」「14日間無料」等） */
	badge?: string;
	/** アイコン画像URL（省略可） */
	iconUrl?: string;
}

const { name, url, description, cta = '詳細を見る', badge, iconUrl } = Astro.props;
---

<div class="asp-link">
	<div class="asp-link-header">
		{iconUrl && (
			<img src={iconUrl} alt={name} class="asp-link-icon" width="32" height="32" loading="lazy" />
		)}
		<div class="asp-link-info">
			<span class="asp-link-name">{name}</span>
			{badge && <span class="asp-link-badge">{badge}</span>}
		</div>
	</div>
	{description && <p class="asp-link-desc">{description}</p>}
		<a href={url} target="_blank" rel="nofollow noopener noreferrer sponsored" class="asp-link-btn">
		{cta}
		<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
			<path d="M7 17L17 7" /><path d="M7 7h10v10" />
		</svg>
	</a>
</div>

<style>
	.asp-link {
		background-color: var(--color-bg-card);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		padding: 1.25rem;
		margin: 1.5rem 0;
		transition: border-color 0.2s;
	}

	.asp-link:hover {
		border-color: var(--color-primary);
	}

	.asp-link-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.5rem;
	}

	.asp-link-icon {
		border-radius: 6px;
		object-fit: contain;
	}

	.asp-link-info {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.asp-link-name {
		font-weight: 700;
		font-size: 1rem;
		color: var(--color-text-heading);
	}

	.asp-link-badge {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: 600;
		padding: 0.15em 0.5em;
		border-radius: 3px;
		background-color: rgba(34, 197, 94, 0.15);
		color: var(--color-success);
	}

	.asp-link-desc {
		font-size: 0.9rem;
		color: var(--color-text-muted);
		margin: 0 0 0.75rem;
		line-height: 1.6;
	}

	.asp-link-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.5em 1.25em;
		background-color: var(--color-primary);
		color: #fff;
		font-size: 0.85rem;
		font-weight: 600;
		border-radius: 6px;
		text-decoration: none;
		transition: opacity 0.2s;
	}

	.asp-link-btn:hover {
		opacity: 0.85;
		text-decoration: none;
	}

	.asp-link-btn svg {
		flex-shrink: 0;
	}

	@media (max-width: 768px) {
		.asp-link {
			padding: 1rem;
		}
	}
</style>
