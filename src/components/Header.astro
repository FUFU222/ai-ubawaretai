---
import { SITE_TITLE } from '../consts';

const pathname = Astro.url.pathname;
const navItems = [
	{ href: '/', label: 'ホーム' },
	{ href: '/blog', label: 'ブログ' },
	{ href: '/category', label: 'カテゴリ' },
	{ href: '/about', label: 'About' },
	{ href: '/editorial-policy', label: '編集方針' },
];
---

<header>
	<nav>
		<a href="/" class="logo" aria-label={SITE_TITLE}>
			<span class="logo-mark" aria-hidden="true">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
					<rect x="3.5" y="3.5" width="17" height="17" rx="5"></rect>
					<path d="M8 15.5 12 8.5l4 7"></path>
					<path d="M10.2 13h3.6"></path>
				</svg>
			</span>
			<span class="logo-text">{SITE_TITLE}</span>
		</a>
		<div class="desktop-nav">
			<div class="nav-links">
				{
					navItems.map(({ href, label }) => (
						<a
							href={href}
							class:list={[{ active: pathname === href || (href !== '/' && pathname.startsWith(href)) }]}
						>
							{label}
						</a>
					))
				}
			</div>
			<button class="theme-toggle desktop-theme-toggle" data-theme-toggle type="button" aria-label="テーマ切り替え">
				<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
				<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
			</button>
		</div>
		<details class="mobile-nav">
			<summary class="mobile-menu-toggle" aria-label="モバイルメニュー">
				<svg class="menu-icon menu-icon-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
					<line x1="4" y1="7" x2="20" y2="7"></line>
					<line x1="4" y1="12" x2="20" y2="12"></line>
					<line x1="4" y1="17" x2="20" y2="17"></line>
				</svg>
				<svg class="menu-icon menu-icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
					<line x1="6" y1="6" x2="18" y2="18"></line>
					<line x1="18" y1="6" x2="6" y2="18"></line>
				</svg>
			</summary>
			<div class="mobile-menu-panel">
				<div class="mobile-menu-links">
					{
						navItems.map(({ href, label }) => (
							<a
								href={href}
								class:list={['mobile-menu-link', { active: pathname === href || (href !== '/' && pathname.startsWith(href)) }]}
							>
								{label}
							</a>
						))
					}
				</div>
				<button class="theme-toggle mobile-theme-toggle" data-theme-toggle type="button">
					<span class="mobile-theme-copy">テーマ切替</span>
					<span class="mobile-theme-icons" aria-hidden="true">
						<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
						<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
					</span>
				</button>
			</div>
		</details>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background-color: var(--header-bg);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--color-border);
		height: var(--header-height);
	}

	nav {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 1rem;
		height: 100%;
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		flex: 1;
		min-width: 0;
		font-size: 1rem;
		font-weight: 700;
		color: var(--color-text-heading);
		text-decoration: none;
		white-space: nowrap;
	}

	.logo-mark {
		flex: none;
		width: 1.15rem;
		height: 1.15rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--color-primary-light);
		opacity: 0.95;
	}

	.logo-mark svg {
		width: 100%;
		height: 100%;
	}

	.logo-text {
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.logo:hover {
		color: var(--color-primary-light);
		text-decoration: none;
	}

	.desktop-nav {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		margin-left: 1rem;
	}

	.nav-links {
		display: flex;
		gap: 0.25rem;
	}

	.nav-links a {
		padding: 0.5rem 0.75rem;
		color: var(--color-text-muted);
		font-size: 0.875rem;
		font-weight: 500;
		text-decoration: none;
		border-radius: 6px;
		transition: color 0.2s, background-color 0.2s;
	}

	.nav-links a:hover {
		color: var(--color-text-heading);
		background-color: var(--color-bg-card);
		text-decoration: none;
	}

	.nav-links a.active {
		color: var(--color-primary-light);
		background-color: rgba(59, 130, 246, 0.1);
	}

	.theme-toggle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		border: none;
		border-radius: 6px;
		background: transparent;
		color: var(--color-text-muted);
		cursor: pointer;
		transition: color 0.2s, background-color 0.2s;
	}

	.theme-toggle:hover {
		color: var(--color-text-heading);
		background-color: var(--color-bg-card);
	}

	.mobile-nav {
		display: none;
	}

	.mobile-menu-toggle {
		list-style: none;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 38px;
		height: 38px;
		border-radius: 10px;
		color: var(--color-text-muted);
		background-color: transparent;
		cursor: pointer;
		transition: color 0.2s, background-color 0.2s;
	}

	.mobile-menu-toggle::-webkit-details-marker {
		display: none;
	}

	.mobile-menu-toggle:hover {
		color: var(--color-text-heading);
		background-color: var(--color-bg-card);
	}

	.menu-icon-close {
		display: none;
	}

	.mobile-nav[open] .menu-icon-open {
		display: none;
	}

	.mobile-nav[open] .menu-icon-close {
		display: block;
	}

	.mobile-menu-panel {
		position: absolute;
		top: calc(100% + 0.5rem);
		right: 0;
		width: min(260px, calc(100vw - 2rem));
		padding: 0.5rem;
		background: color-mix(in srgb, var(--color-bg-card) 88%, transparent);
		border: 1px solid var(--color-border);
		border-radius: 14px;
		box-shadow: 0 18px 40px rgba(15, 23, 42, 0.16);
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
		animation: mobile-menu-in 0.18s ease-out;
	}

	.mobile-menu-links {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.mobile-menu-link {
		display: flex;
		align-items: center;
		padding: 0.8rem 0.9rem;
		border-radius: 10px;
		color: var(--color-text-heading);
		font-size: 0.92rem;
		font-weight: 600;
		text-decoration: none;
	}

	.mobile-menu-link:hover {
		background-color: var(--color-bg-card);
		text-decoration: none;
	}

	.mobile-menu-link.active {
		background-color: rgba(59, 130, 246, 0.12);
		color: var(--color-primary-light);
	}

	.mobile-theme-toggle {
		width: 100%;
		height: auto;
		margin-top: 0.4rem;
		padding: 0.8rem 0.9rem;
		border-radius: 10px;
		justify-content: space-between;
		border-top: 1px solid color-mix(in srgb, var(--color-border) 65%, transparent);
	}

	.mobile-theme-copy {
		font-size: 0.9rem;
		font-weight: 600;
	}

	.mobile-theme-icons {
		display: inline-flex;
		align-items: center;
	}

	:global(:root[data-theme='light']) .icon-sun { display: none; }
	:global(:root[data-theme='light']) .icon-moon { display: block; }
	.icon-sun { display: block; }
	.icon-moon { display: none; }

	@keyframes mobile-menu-in {
		from {
			opacity: 0;
			transform: translateY(-6px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 768px) {
		header {
			height: 56px;
		}

		nav {
			padding: 0 0.85rem;
			gap: 0.75rem;
		}

		.logo {
			font-size: 0.9rem;
		}

		.logo-mark {
			width: 1rem;
			height: 1rem;
		}

		.desktop-nav {
			display: none;
		}

		.mobile-nav {
			display: block;
		}
	}
</style>

<script>
	const applyThemeToggle = () => {
		const root = document.documentElement;
		const isLight = root.getAttribute('data-theme') === 'light';
		if (isLight) {
			root.removeAttribute('data-theme');
			localStorage.setItem('theme', 'dark');
			return;
		}

		root.setAttribute('data-theme', 'light');
		localStorage.setItem('theme', 'light');
	};

	document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
		button.addEventListener('click', applyThemeToggle);
	});

	const mobileNav = document.querySelector('.mobile-nav');

	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape') {
			mobileNav?.removeAttribute('open');
		}
	});

	document.addEventListener('click', (event) => {
		if (!mobileNav?.hasAttribute('open')) {
			return;
		}

		if (!mobileNav.contains(event.target)) {
			mobileNav.removeAttribute('open');
		}
	});
</script>
