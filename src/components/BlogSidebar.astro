---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import PostThumbnail from './PostThumbnail.astro';
import { getCategoryPath, getCategorySummaries } from '../utils/categories';
import { getTagPath, getTagSummaries } from '../utils/tags';

interface Props {
	currentId: string;
	tags: string[];
	category?: string;
	posts?: CollectionEntry<'blog'>[];
}

const { currentId, tags, category, posts } = Astro.props;

const allPosts = posts ?? (await getCollection('blog', ({ data }) => !data.draft));
const candidates = allPosts.filter((post) => post.id !== currentId);
const tagSet = new Set(tags);
const now = Date.now();

function recencyScore(post: CollectionEntry<'blog'>) {
	const ageDays = Math.max(0, (now - post.data.pubDate.getTime()) / (1000 * 60 * 60 * 24));
	return Math.exp(-ageDays / 90);
}

const categorySummaries = getCategorySummaries(allPosts);
const topicSummaries = getTagSummaries(allPosts).filter((tag) => tag.isIndexable);
const browseItems =
	categorySummaries.length > 1
		? categorySummaries.slice(0, 6).map((item) => ({
				href: getCategoryPath(item.slug),
				label: item.label,
				count: item.count,
			}))
		: topicSummaries.slice(0, 8).map((item) => ({
				href: getTagPath(item.slug),
				label: item.label,
				count: item.count,
			}));
const recommendedPosts = candidates
	.map((post) => {
		const sharedTags = post.data.tags.filter((tag) => tagSet.has(tag)).length;
		const sameCategory = category && post.data.category === category ? 1 : 0;
		const pillarBonus = post.data.pillar ? 1 : 0;
		const score = sharedTags * 4 + sameCategory * 1.5 + pillarBonus + recencyScore(post);
		return { post, score };
	})
	.sort((left, right) => {
		const scoreDiff = right.score - left.score;
		if (scoreDiff !== 0) {
			return scoreDiff;
		}

		return right.post.data.pubDate.valueOf() - left.post.data.pubDate.valueOf();
	})
	.slice(0, 4)
	.map(({ post }) => post);

const latestPosts = [...candidates]
	.sort((left, right) => right.data.pubDate.valueOf() - left.data.pubDate.valueOf())
	.slice(0, 3);
---

<nav class="blog-sidebar" aria-label="ブログ内を移動">
	<section class="sidebar-section" aria-labelledby="sidebar-categories-title">
		<p class="sidebar-eyebrow">Browse</p>
		<h2 id="sidebar-categories-title">カテゴリ / トピック</h2>
		<div class="category-list">
			{
				browseItems.map((item) => (
					<a href={item.href} class="category-link">
						<span>{item.label}</span>
						<small>{item.count}</small>
					</a>
				))
			}
		</div>
	</section>

	{
		recommendedPosts.length > 0 && (
			<section class="sidebar-section" aria-labelledby="sidebar-recommended-title">
				<p class="sidebar-eyebrow">Recommended</p>
				<h2 id="sidebar-recommended-title">おすすめ記事</h2>
				<ol class="recommended-list">
					{recommendedPosts.map((post, index) => (
						<li>
							<a href={`/blog/${post.id}/`} class="recommended-link">
								<span class="recommended-media">
									<PostThumbnail
										post={post}
										context="sidebar-recommended"
										class="recommended-thumb"
										width={112}
										height={63}
									/>
									<span class="rank-number">{String(index + 1).padStart(2, '0')}</span>
								</span>
								<span class="recommended-copy">
									<strong>{post.data.title}</strong>
									<small>
										<FormattedDate date={post.data.pubDate} />
									</small>
								</span>
							</a>
						</li>
					))}
				</ol>
			</section>
		)
	}

	{
		latestPosts.length > 0 && (
			<section class="sidebar-section" aria-labelledby="sidebar-latest-title">
				<p class="sidebar-eyebrow">Latest</p>
				<h2 id="sidebar-latest-title">最新記事</h2>
				<div class="latest-list">
					{latestPosts.map((post) => (
						<a href={`/blog/${post.id}/`} class="latest-link">
							<PostThumbnail
								post={post}
								context="sidebar-latest"
								class="latest-thumb"
								width={112}
								height={63}
							/>
							<span class="latest-copy">
								<small>
									<FormattedDate date={post.data.pubDate} />
								</small>
								<strong>{post.data.title}</strong>
							</span>
						</a>
					))}
				</div>
			</section>
		)
	}
</nav>

<style>
	.blog-sidebar {
		display: grid;
		gap: 1.45rem;
		color: var(--color-text);
	}

	.sidebar-section {
		padding-top: 0.95rem;
		border-top: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
	}

	.sidebar-section:first-child {
		padding-top: 0;
		border-top: 0;
	}

	.sidebar-eyebrow {
		margin: 0 0 0.35rem;
		color: #f59e0b;
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.sidebar-section h2 {
		margin: 0 0 0.75rem;
		padding: 0;
		border: 0;
		font-size: 0.95rem;
		line-height: 1.45;
	}

	.category-list,
	.latest-list {
		display: grid;
		gap: 0.55rem;
	}

	.category-link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 0.48rem 0;
		border-bottom: 1px solid color-mix(in srgb, var(--color-border) 48%, transparent);
		color: var(--color-text);
		font-size: 0.84rem;
		font-weight: 700;
		text-decoration: none;
	}

	.category-link:hover,
	.recommended-link:hover,
	.latest-link:hover {
		color: var(--color-primary-light);
		text-decoration: none;
	}

	.category-link small {
		color: var(--color-text-muted);
		font-size: 0.72rem;
		font-variant-numeric: tabular-nums;
	}

	.recommended-list {
		display: grid;
		gap: 0.8rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.recommended-list li {
		margin: 0;
	}

	.recommended-link {
		display: grid;
		grid-template-columns: 4.4rem minmax(0, 1fr);
		align-items: start;
		gap: 0.62rem;
		color: var(--color-text);
		text-decoration: none;
	}

	.recommended-media {
		position: relative;
		display: block;
		min-width: 0;
	}

	.rank-number {
		position: absolute;
		top: 0.25rem;
		left: 0.25rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 1.45rem;
		min-height: 1.2rem;
		padding: 0 0.25rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--color-bg) 84%, transparent);
		color: var(--color-text-heading);
		font-size: 0.62rem;
		font-weight: 800;
		line-height: 1;
		font-variant-numeric: tabular-nums;
	}

	.recommended-copy,
	.latest-copy {
		display: grid;
		gap: 0.22rem;
		min-width: 0;
	}

	.recommended-copy strong,
	.latest-copy strong {
		color: inherit;
		font-size: 0.82rem;
		line-height: 1.55;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.recommended-copy small,
	.latest-copy small {
		color: var(--color-text-muted);
		font-size: 0.72rem;
		line-height: 1.35;
	}

	.latest-link {
		display: grid;
		grid-template-columns: 4.4rem minmax(0, 1fr);
		align-items: start;
		gap: 0.62rem;
		padding-bottom: 0.6rem;
		border-bottom: 1px solid color-mix(in srgb, var(--color-border) 48%, transparent);
		color: var(--color-text);
		text-decoration: none;
	}

	@media (max-width: 1139px) {
		.blog-sidebar {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			gap: 1rem;
		}

		.sidebar-section,
		.sidebar-section:first-child {
			padding-top: 0.95rem;
			border-top: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
		}
	}

	@media (max-width: 760px) {
		.blog-sidebar {
			grid-template-columns: 1fr;
		}
	}
</style>
