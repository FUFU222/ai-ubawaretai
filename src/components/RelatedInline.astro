---
import { getCollection } from 'astro:content';

interface Props {
	slug: string;
	label?: string;
}

const { slug, label = '関連記事' } = Astro.props;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const target = allPosts.find((post) => post.id === slug);

if (!target) {
	throw new Error(
		`<RelatedInline slug="${slug}" /> が参照する記事が見つかりません。src/content/blog 配下のIDを確認してください。`,
	);
}
---

<aside class="related-inline" aria-label={label}>
	<a href={`/blog/${target.id}/`} class="related-inline-link">
		<span class="related-inline-eyebrow">📎 {label}</span>
		<span class="related-inline-title">{target.data.title}</span>
		{target.data.description && (
			<span class="related-inline-desc">{target.data.description}</span>
		)}
	</a>
</aside>

<style>
	.related-inline {
		margin: 1.75rem 0;
		border-left: 3px solid var(--color-primary-light, #60a5fa);
		background: color-mix(in srgb, var(--color-bg-card) 70%, transparent);
		border-radius: 0 10px 10px 0;
	}

	.related-inline-link {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: 0.85rem 1rem;
		text-decoration: none;
		color: inherit;
		transition: background 0.2s;
	}

	.related-inline-link:hover {
		background: color-mix(in srgb, var(--color-primary-light, #60a5fa) 8%, transparent);
		text-decoration: none;
	}

	.related-inline-eyebrow {
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		color: var(--color-text-muted);
		text-transform: uppercase;
	}

	.related-inline-title {
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.5;
		color: var(--color-text-heading);
	}

	.related-inline-link:hover .related-inline-title {
		color: var(--color-primary-light, #60a5fa);
	}

	.related-inline-desc {
		font-size: 0.85rem;
		line-height: 1.6;
		color: var(--color-text-muted);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
