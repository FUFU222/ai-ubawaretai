---
/**
 * Google AdSense 広告ユニット
 *
 * 使い方:
 *   <AdSense slot="1234567890" />
 *   <AdSense slot="1234567890" format="horizontal" />
 *
 * 審査通過前はプレースホルダーを表示。
 * 審査通過後、環境変数 ADSENSE_CLIENT_ID を設定するとリアル広告に切り替わる。
 */
interface Props {
	/** AdSense 広告スロット ID */
	slot?: string;
	/** 広告フォーマット */
	format?: 'auto' | 'rectangle' | 'horizontal' | 'vertical';
	/** 配置ラベル（デバッグ用） */
	label?: string;
}

const { slot, format = 'auto', label } = Astro.props;
const clientId = import.meta.env.ADSENSE_CLIENT_ID || '';
const isLive = clientId.length > 0 && slot;

// フォーマットごとの最小高さ（CLS防止）
const minHeights: Record<string, string> = {
	auto: '250px',
	rectangle: '250px',
	horizontal: '90px',
	vertical: '600px',
};
const minHeight = minHeights[format] || '250px';
---

<div class="ad-container" style={`min-height: ${minHeight}`} data-ad-format={format}>
	{
		isLive ? (
			<ins
				class="adsbygoogle"
				style="display:block"
				data-ad-client={clientId}
				data-ad-slot={slot}
				data-ad-format={format === 'auto' ? 'auto' : undefined}
				data-full-width-responsive={format === 'auto' ? 'true' : undefined}
			/>
		) : (
			<div class="ad-placeholder">
				<span class="ad-placeholder-label">
					{label ? `Ad: ${label}` : 'Ad'}
				</span>
			</div>
		)
	}
</div>

{isLive && (
	<script is:inline>
		(adsbygoogle = window.adsbygoogle || []).push({});
	</script>
)}

<style>
	.ad-container {
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 2rem 0;
		overflow: hidden;
	}

	.ad-placeholder {
		width: 100%;
		height: 100%;
		min-height: inherit;
		display: flex;
		align-items: center;
		justify-content: center;
		background-color: var(--color-bg-card);
		border: 1px dashed var(--color-border);
		border-radius: 8px;
	}

	.ad-placeholder-label {
		color: var(--color-text-muted);
		font-size: 0.7rem;
		opacity: 0.4;
		letter-spacing: 0.05em;
	}
</style>
