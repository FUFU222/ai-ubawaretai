---
interface Props {
	slot?: string;
	format?: 'auto' | 'rectangle' | 'horizontal';
}
---

<div class="ad-container">
	<span class="ad-label">Ad</span>
</div>

<style>
	.ad-container {
		min-height: 250px;
		display: flex;
		align-items: center;
		justify-content: center;
		background-color: var(--color-bg-card);
		border: 1px dashed var(--color-border);
		border-radius: 8px;
		margin: 2rem 0;
	}

	.ad-label {
		color: var(--color-text-muted);
		font-size: 0.75rem;
		opacity: 0.5;
	}
</style>
