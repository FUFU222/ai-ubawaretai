---
interface Props {
	label: string;
	class?: string;
}
const { label, class: className } = Astro.props;
---

<span class:list={['category-badge', className]}>{label}</span>

<style>
	.category-badge {
		display: inline-block;
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--color-primary-light);
		background-color: rgba(59, 130, 246, 0.1);
		padding: 0.15em 0.5em;
		border-radius: 3px;
	}
</style>
