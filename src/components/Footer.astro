---
import { SITE_TITLE } from '../consts';

const year = new Date().getFullYear();
---

<footer>
	<div class="footer-inner">
		<div class="footer-nav">
			<p class="footer-eyebrow">Information</p>
			<div class="footer-link-grid">
				<a href="/about">About</a>
				<a href="/contact">お問い合わせ</a>
				<a href="/privacy">プライバシーポリシー</a>
			</div>
		</div>
		<div class="footer-meta">
			<p class="footer-site-title">{SITE_TITLE}</p>
			<p class="tagline">AI・ソフトウェア・プロダクトの更新を、日本の事業と開発の文脈で整理するブログです。</p>
			<p class="copyright">&copy; {year} {SITE_TITLE}. All rights reserved.</p>
		</div>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--color-border);
		margin-top: 4rem;
		padding: 2.5rem 1rem 2rem;
	}

	.footer-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		text-align: center;
		display: grid;
		gap: 1.5rem;
	}

	.footer-nav {
		display: grid;
		gap: 0.75rem;
	}

	.footer-eyebrow {
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-text-muted);
		opacity: 0.8;
	}

	.footer-link-grid {
		display: grid;
		grid-template-columns: repeat(1, minmax(0, 1fr));
		gap: 0.75rem;
	}

	.footer-link-grid a {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 3rem;
		padding: 0.8rem 0.9rem;
		border: 1px solid color-mix(in srgb, var(--color-border) 78%, transparent);
		border-radius: 12px;
		background: color-mix(in srgb, var(--color-bg-card) 88%, transparent);
		color: var(--color-text-muted);
		font-size: 0.875rem;
		font-weight: 600;
		line-height: 1.45;
		word-break: keep-all;
		overflow-wrap: normal;
		text-wrap: balance;
		text-decoration: none;
	}

	.footer-link-grid a:hover {
		color: var(--color-primary-light);
		border-color: color-mix(in srgb, var(--color-primary-light) 45%, var(--color-border));
		text-decoration: none;
	}

	.footer-meta {
		display: grid;
		gap: 0.55rem;
		padding-top: 1.25rem;
		border-top: 1px solid color-mix(in srgb, var(--color-border) 72%, transparent);
	}

	.footer-site-title {
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--color-text-heading);
	}

	.tagline {
		color: var(--color-text-muted);
		font-size: 0.84rem;
		line-height: 1.8;
		max-width: 32rem;
		margin: 0 auto;
	}

	.copyright {
		color: var(--color-text-muted);
		font-size: 0.8rem;
	}

	@media (min-width: 769px) {
		.footer-link-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (max-width: 480px) {
		.footer-link-grid a {
			min-height: 2.8rem;
		}
	}
</style>
