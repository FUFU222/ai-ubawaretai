---
import {
	ARTICLE_LEVEL_LABELS,
	ARTICLE_LEVEL_SEQUENCE,
	getArticleLevelPath,
	type ArticleLevelAvailability,
	type ArticleLevelVariant,
} from '../utils/articleLevels';

type Props = {
	articleId: string;
	availability: ArticleLevelAvailability;
};

const { articleId, availability } = Astro.props;
const routes = Object.fromEntries(
	Object.entries(availability).map(([level]) => [level, getArticleLevelPath(articleId, level as ArticleLevelVariant)]),
);
const supportedLevels = ARTICLE_LEVEL_SEQUENCE.filter(
	(level) => level === 'standard' || availability[level as ArticleLevelVariant],
);
---

<div
	class="article-level-shell"
	data-article-level-switcher
	data-article-level-behavior="dock-on-read"
	data-article-default-level="standard"
	data-article-level-routes={JSON.stringify(routes)}
	data-article-level-storage-key="preferred-article-level"
	data-article-level-placement="inline"
>
	<div class="article-level-card">
		<p class="article-level-eyebrow">解説レベル</p>
		<div class="article-level-anchor">
			<button
				class="article-level-trigger"
				type="button"
				aria-expanded="false"
				aria-haspopup="true"
				data-article-level-trigger
			>
				<span class="article-level-trigger-copy">
					<span class="article-level-trigger-label">解説レベル</span>
					<span class="article-level-current" data-article-level-current>{ARTICLE_LEVEL_LABELS.standard}</span>
				</span>
				<svg
					class="article-level-chevron"
					xmlns="http://www.w3.org/2000/svg"
					width="18"
					height="18"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<polyline points="6 9 12 15 18 9"></polyline>
				</svg>
			</button>
			<div class="article-level-menu" hidden data-article-level-menu>
				{
					supportedLevels.map((level) => (
						<button
							class:list={['article-level-option', { active: level === 'standard' }]}
							type="button"
							data-article-level-option
							data-level={level}
						>
							{ARTICLE_LEVEL_LABELS[level]}
						</button>
					))
				}
			</div>
		</div>
	</div>
</div>

<style>
	.article-level-shell {
		position: sticky;
		top: calc(var(--header-height) + 0.8rem);
		z-index: 40;
		display: flex;
		justify-content: center;
		width: 100%;
		margin: 0 0 1.6rem;
		pointer-events: none;
	}

	.article-level-card {
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
		width: min(100%, 320px);
		padding: 0.55rem;
		border: 1px solid color-mix(in srgb, var(--color-border) 86%, transparent);
		border-radius: 18px;
		background: color-mix(in srgb, var(--color-bg-card) 86%, transparent);
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
		box-shadow: 0 14px 34px rgba(15, 23, 42, 0.12);
		pointer-events: auto;
		transition: padding 0.18s ease, border-radius 0.18s ease, box-shadow 0.18s ease;
	}

	.article-level-shell.is-docked-right {
		position: fixed;
		top: calc(var(--header-height) + 0.9rem);
		left: var(--article-level-dock-left, auto);
		width: var(--article-level-dock-width, 220px);
		margin: 0;
		justify-content: flex-start;
		z-index: 60;
	}

	.article-level-shell.is-docked-right .article-level-card {
		width: 100%;
	}

	.article-level-eyebrow {
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-muted);
		padding: 0 0.35rem;
		transition: opacity 0.18s ease, transform 0.18s ease, max-height 0.18s ease;
		max-height: 1rem;
	}

	.article-level-anchor {
		position: relative;
	}

	.article-level-trigger {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.9rem;
		width: 100%;
		min-height: 50px;
		padding: 0.8rem 0.95rem;
		border: 1px solid color-mix(in srgb, var(--color-primary-light) 28%, var(--color-border));
		border-radius: 14px;
		background: color-mix(in srgb, var(--color-bg) 18%, var(--color-bg-card));
		color: var(--color-text-heading);
		cursor: pointer;
		transition: border-color 0.18s ease, background-color 0.18s ease, transform 0.18s ease;
	}

	.article-level-trigger:hover {
		border-color: color-mix(in srgb, var(--color-primary-light) 48%, var(--color-border));
		background: color-mix(in srgb, var(--color-primary) 10%, var(--color-bg-card));
	}

	.article-level-trigger:focus-visible {
		outline: 2px solid color-mix(in srgb, var(--color-primary-light) 72%, white);
		outline-offset: 2px;
	}

	.article-level-trigger:disabled {
		cursor: progress;
	}

	.article-level-trigger-copy {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.15rem;
		min-width: 0;
	}

	.article-level-trigger-label {
		font-size: 0.72rem;
		color: var(--color-text-muted);
	}

	.article-level-current {
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--color-text-heading);
	}

	.article-level-chevron {
		flex: none;
		color: var(--color-text-muted);
		transition: transform 0.18s ease;
	}

	.article-level-menu {
		position: absolute;
		left: 0;
		right: 0;
		top: calc(100% + 0.55rem);
		display: grid;
		gap: 0.35rem;
		padding: 0.4rem;
		border: 1px solid color-mix(in srgb, var(--color-border) 86%, transparent);
		border-radius: 16px;
		background: color-mix(in srgb, var(--color-bg-card) 92%, transparent);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		box-shadow: 0 18px 38px rgba(15, 23, 42, 0.16);
		transform-origin: top center;
		animation: article-level-menu-in 0.18s ease-out;
	}

	.article-level-option {
		display: flex;
		align-items: center;
		width: 100%;
		min-height: 46px;
		padding: 0.75rem 0.85rem;
		border: 1px solid transparent;
		border-radius: 12px;
		background: transparent;
		color: var(--color-text);
		font: inherit;
		font-weight: 600;
		text-align: left;
		cursor: pointer;
		transition: background-color 0.18s ease, border-color 0.18s ease, color 0.18s ease;
	}

	.article-level-option:hover,
	.article-level-option:focus-visible {
		background: color-mix(in srgb, var(--color-primary) 10%, var(--color-bg-card));
		border-color: color-mix(in srgb, var(--color-primary-light) 28%, var(--color-border));
		color: var(--color-text-heading);
		outline: none;
	}

	.article-level-option.active {
		background: color-mix(in srgb, var(--color-primary) 14%, var(--color-bg-card));
		border-color: color-mix(in srgb, var(--color-primary-light) 42%, var(--color-border));
		color: var(--color-primary-light);
	}

	.article-level-shell.is-open .article-level-chevron {
		transform: rotate(180deg);
	}

	.article-level-shell.is-compact .article-level-card {
		padding: 0.4rem;
		border-radius: 14px;
		box-shadow: 0 12px 28px rgba(15, 23, 42, 0.12);
	}

	.article-level-shell.is-compact .article-level-eyebrow {
		opacity: 0;
		transform: translateY(-4px);
		max-height: 0;
		overflow: hidden;
	}

	.article-level-shell.is-compact .article-level-trigger {
		min-height: 44px;
		padding-block: 0.65rem;
	}

	.article-level-shell.is-compact .article-level-trigger-label {
		display: none;
	}

	.article-level-shell.is-loading .article-level-trigger {
		border-color: color-mix(in srgb, var(--color-primary-light) 42%, var(--color-border));
	}

	@keyframes article-level-menu-in {
		from {
			opacity: 0;
			transform: translateY(-6px) scale(0.98);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	@media (max-width: 768px) {
		.article-level-shell {
			top: calc(var(--header-height) + 0.65rem);
			margin-bottom: 1.25rem;
		}

		.article-level-card {
			width: 100%;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.article-level-card,
		.article-level-eyebrow,
		.article-level-trigger,
		.article-level-chevron,
		.article-level-option {
			transition: none;
		}

		.article-level-menu {
			animation: none;
		}
	}
</style>

<script is:inline>
	(() => {
		const init = () => {
			const root = document.querySelector('[data-article-level-switcher]');
			const prose = document.querySelector('[data-article-level-target]');

			if (!(root instanceof HTMLElement) || !(prose instanceof HTMLElement)) {
				return;
			}

			const trigger = root.querySelector('[data-article-level-trigger]');
			const current = root.querySelector('[data-article-level-current]');
			const menu = root.querySelector('[data-article-level-menu]');
			const options = Array.from(root.querySelectorAll('[data-article-level-option]'));

			if (
				!(trigger instanceof HTMLButtonElement) ||
				!(current instanceof HTMLElement) ||
				!(menu instanceof HTMLElement) ||
				options.length === 0
			) {
				return;
			}

			const article = prose.closest('[data-article-level-article]');

			const routes = JSON.parse(root.dataset.articleLevelRoutes || '{}');
			const storageKey = root.dataset.articleLevelStorageKey || 'preferred-article-level';
			const defaultLevel = root.dataset.articleDefaultLevel || 'standard';
			const labels = Object.fromEntries(
				options.map((option) => [option.getAttribute('data-level'), option.textContent?.trim() ?? '']),
			);
			const cache = {
				standard: prose.innerHTML,
			};

			let activeLevel = defaultLevel;
			let requestToken = 0;
			let isDockedRight = false;
			let lastScrollY = window.scrollY;

			const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const dockWidth = 220;
			const dockGap = 24;
			const dockViewportPadding = 20;
			const dockViewportMinWidth = 1200;

		const getHeaderHeight = () =>
			parseInt(getComputedStyle(document.documentElement).getPropertyValue('--header-height') || '60', 10);

		const animatePlacement = (firstRect, lastRect) => {
			if (
				prefersReducedMotion ||
				typeof root.animate !== 'function' ||
				(!firstRect && !lastRect)
			) {
				return;
			}

			const deltaX = firstRect.left - lastRect.left;
			const deltaY = firstRect.top - lastRect.top;

			if (Math.abs(deltaX) < 1 && Math.abs(deltaY) < 1) {
				return;
			}

			root.animate(
				[
					{ transform: `translate(${deltaX}px, ${deltaY}px)` },
					{ transform: 'translate(0, 0)' },
				],
				{
					duration: 280,
					easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
				},
			);
		};

		const setCompact = () => {
			const headerHeight = getHeaderHeight();
			const proseTop = prose.getBoundingClientRect().top;
			const shouldCompact =
				isDockedRight ||
				(window.scrollY > 0 && proseTop <= headerHeight + 90);

			root.classList.toggle('is-compact', shouldCompact);
		};

		const setOpen = (isOpen) => {
			root.classList.toggle('is-open', isOpen);
			trigger.setAttribute('aria-expanded', String(isOpen));
			menu.hidden = !isOpen;
		};

		const getDockMetrics = () => {
			if (!(article instanceof HTMLElement)) {
				return { canDock: false, left: 0 };
			}

			const articleRect = article.getBoundingClientRect();
			const minLeft = articleRect.right + 12;
			const maxLeft = window.innerWidth - dockWidth - dockViewportPadding;
			const preferredLeft = articleRect.right + dockGap;
			const canDock =
				window.innerWidth >= dockViewportMinWidth &&
				maxLeft >= minLeft;

			return {
				canDock,
				left: Math.min(preferredLeft, maxLeft),
			};
		};

		const applyDockState = (shouldDock, dockLeft) => {
			if (shouldDock && Number.isFinite(dockLeft)) {
				root.style.setProperty('--article-level-dock-left', `${dockLeft}px`);
				root.style.setProperty('--article-level-dock-width', `${dockWidth}px`);
			}

			if (shouldDock === isDockedRight) {
				root.setAttribute('data-article-level-placement', shouldDock ? 'right-rail' : 'inline');
				return;
			}

			const firstRect = root.getBoundingClientRect();

			if (shouldDock) {
				root.classList.add('is-docked-right');
				root.setAttribute('data-article-level-placement', 'right-rail');
			} else {
				root.classList.remove('is-docked-right');
				root.setAttribute('data-article-level-placement', 'inline');
			}

			isDockedRight = shouldDock;
			const lastRect = root.getBoundingClientRect();
			animatePlacement(firstRect, lastRect);
		};

		const updatePlacement = () => {
			const headerHeight = getHeaderHeight();
			const proseTop = prose.getBoundingClientRect().top;
			const { canDock, left } = getDockMetrics();
			const shouldDock = canDock && proseTop <= headerHeight + 42;

			if (root.classList.contains('is-open') && (shouldDock || Math.abs(window.scrollY - lastScrollY) > 3)) {
				setOpen(false);
			}

			applyDockState(shouldDock, left);
			setCompact();
			lastScrollY = window.scrollY;
		};

		const setActiveLevel = (level) => {
			activeLevel = level;
			current.textContent = labels[level] || labels.standard || '標準';

			options.forEach((option) => {
				const isActive = option.getAttribute('data-level') === level;
				option.classList.toggle('active', isActive);
				option.setAttribute('aria-pressed', String(isActive));
			});
		};

		const animateSwap = (html) => {
			if (prefersReducedMotion) {
				prose.innerHTML = html;
				return;
			}

			prose.classList.remove('is-level-switching-in');
			prose.classList.add('is-level-switching-out');

			window.setTimeout(() => {
				prose.innerHTML = html;
				prose.classList.remove('is-level-switching-out');
				prose.classList.add('is-level-switching-in');

				window.setTimeout(() => {
					prose.classList.remove('is-level-switching-in');
				}, 240);
			}, 120);
		};

		const fetchLevel = async (level) => {
			if (cache[level]) {
				return cache[level];
			}

			const route = routes[level];

			if (!route) {
				throw new Error(`Missing article level route for ${level}`);
			}

			const response = await fetch(route, {
				headers: { 'X-Requested-With': 'article-level-switcher' },
			});

			if (!response.ok) {
				throw new Error(`Failed to fetch article level ${level}`);
			}

			const html = await response.text();
			cache[level] = html;
			return html;
		};

		const prefetchAdditionalLevels = () => {
			Object.keys(routes).forEach((level) => {
				void fetchLevel(level).catch(() => {
					// Quietly keep the current prose if a variant payload is unavailable.
				});
			});
		};

		const switchLevel = async (level) => {
			if (level === activeLevel) {
				setOpen(false);
				return;
			}

			const nextToken = requestToken + 1;
			requestToken = nextToken;
			root.classList.add('is-loading');
			trigger.disabled = true;
			setOpen(false);

			try {
				const html = level === 'standard' ? cache.standard : await fetchLevel(level);

				if (requestToken !== nextToken) {
					return;
				}

				animateSwap(html);
				setActiveLevel(level);
				try {
					localStorage.setItem(storageKey, level);
				} catch {}
			} catch (error) {
				console.error(error);
			} finally {
				if (requestToken === nextToken) {
					root.classList.remove('is-loading');
					trigger.disabled = false;
				}
			}
		};

		const restorePreference = () => {
			try {
				const saved = localStorage.getItem(storageKey);
				if (!saved || saved === 'standard' || !routes[saved]) {
					return;
				}

				void fetchLevel(saved)
					.then((html) => {
						animateSwap(html);
						setActiveLevel(saved);
					})
					.catch(() => {
						// Stay on standard if the restore target is unavailable.
					});
			} catch {}
		};

			setActiveLevel(defaultLevel);
			setOpen(false);
			updatePlacement();

			trigger.addEventListener('click', () => {
				setOpen(!root.classList.contains('is-open'));
			});

			options.forEach((option) => {
				option.addEventListener('click', () => {
					const nextLevel = option.getAttribute('data-level');
					if (!nextLevel) {
						return;
					}
					void switchLevel(nextLevel);
				});
			});

			document.addEventListener('click', (event) => {
				if (!root.contains(event.target)) {
					setOpen(false);
				}
			});

			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					setOpen(false);
				}
			});

			window.addEventListener('scroll', updatePlacement, { passive: true });
			window.addEventListener('resize', updatePlacement);

			if ('requestIdleCallback' in window) {
				window.requestIdleCallback(prefetchAdditionalLevels, { timeout: 1600 });
			} else {
				window.setTimeout(prefetchAdditionalLevels, 250);
			}

			restorePreference();
		};

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', init, { once: true });
		} else {
			init();
		}
	})();
</script>
