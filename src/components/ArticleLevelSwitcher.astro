---
import {
	ARTICLE_LEVEL_LABELS,
	ARTICLE_LEVEL_SEQUENCE,
	getArticleLevelPath,
	type ArticleLevelAvailability,
	type ArticleLevelVariant,
} from '../utils/articleLevels';

type Props = {
	articleId: string;
	availability: ArticleLevelAvailability;
};

const { articleId, availability } = Astro.props;
const routes = Object.fromEntries(
	Object.entries(availability).map(([level]) => [level, getArticleLevelPath(articleId, level as ArticleLevelVariant)]),
);
const supportedLevels = ARTICLE_LEVEL_SEQUENCE.filter(
	(level) => level === 'standard' || availability[level as ArticleLevelVariant],
);
---

<div
	class="article-level-shell"
	data-article-level-switcher
	data-article-level-behavior="dock-on-read"
	data-article-default-level="standard"
	data-article-level-routes={JSON.stringify(routes)}
	data-article-level-storage-key="preferred-article-level"
	data-article-level-placement="inline"
>
	<button
		class="article-level-scrim"
		type="button"
		aria-label="解説レベルの選択を閉じる"
		hidden
		data-article-level-scrim
	></button>
	<div class="article-level-card">
		<p class="article-level-eyebrow">解説レベル</p>
		<div class="article-level-anchor">
			<button
				class="article-level-trigger"
				type="button"
				aria-expanded="false"
				aria-haspopup="true"
				aria-label={`解説レベル: ${ARTICLE_LEVEL_LABELS.standard}`}
				data-article-level-trigger
			>
				<span class="article-level-trigger-copy">
					<span class="article-level-current" data-article-level-current>{ARTICLE_LEVEL_LABELS.standard}</span>
				</span>
				<svg
					class="article-level-chevron"
					xmlns="http://www.w3.org/2000/svg"
					width="18"
					height="18"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<polyline points="6 9 12 15 18 9"></polyline>
				</svg>
			</button>
			<div class="article-level-menu" hidden data-article-level-menu>
				{
					supportedLevels.map((level) => (
						<button
							class:list={['article-level-option', { active: level === 'standard' }]}
							type="button"
							data-article-level-option
							data-level={level}
						>
							{ARTICLE_LEVEL_LABELS[level]}
						</button>
					))
				}
			</div>
		</div>
	</div>
</div>

<style>
	.article-level-shell {
		position: sticky;
		top: calc(var(--header-height) + 0.8rem);
		z-index: 40;
		display: flex;
		justify-content: center;
		width: 100%;
		margin: 0 0 1.6rem;
		pointer-events: none;
		overflow: visible;
		--article-level-progress: 0;
		--article-level-shift-x: 0px;
		--article-level-shift-y: 0px;
		--article-level-scale: 1;
	}

	.article-level-card {
		position: relative;
		z-index: 2;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.55rem;
		width: min(100%, 320px);
		pointer-events: auto;
		transform: translate3d(var(--article-level-shift-x), var(--article-level-shift-y), 0)
			scale(var(--article-level-scale));
		transform-origin: top left;
		will-change: transform;
		transition: gap 0.18s ease;
	}

	.article-level-scrim {
		position: fixed;
		inset: 0;
		z-index: 1;
		padding: 0;
		border: 0;
		background: rgba(15, 23, 42, 0.3);
		backdrop-filter: blur(3px) saturate(0.92);
		-webkit-backdrop-filter: blur(3px) saturate(0.92);
		cursor: pointer;
		pointer-events: auto;
		animation: article-level-scrim-in 0.16s ease-out;
	}

	.article-level-scrim[hidden] {
		display: none;
	}

	.article-level-shell.is-dock-disabled {
		position: static;
		z-index: auto;
	}

	.article-level-shell.is-dock-disabled .article-level-card {
		transform: none;
	}

	.article-level-eyebrow {
		display: inline-flex;
		align-items: center;
		padding: 0.38rem 0.78rem;
		border-radius: 999px;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		color: white;
		background: linear-gradient(
			135deg,
			var(--color-primary-dark) 0%,
			var(--color-primary) 52%,
			color-mix(in srgb, var(--color-primary-light) 72%, white) 100%
		);
		box-shadow:
			0 10px 24px rgba(37, 99, 235, 0.18),
			inset 0 1px 0 rgba(255, 255, 255, 0.18);
		line-height: 1;
		opacity: calc(1 - var(--article-level-progress));
		transform: translateY(calc(-4px * var(--article-level-progress)));
		transition: opacity 0.18s ease, transform 0.18s ease, max-height 0.18s ease;
		max-height: calc(2rem * (1 - var(--article-level-progress)));
		overflow: hidden;
	}

	.article-level-anchor {
		position: relative;
		width: 100%;
	}

	.article-level-trigger {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.9rem;
		width: 100%;
		min-height: 50px;
		padding: 0.9rem 1rem;
		border: none;
		border-radius: 16px;
		background: linear-gradient(
			135deg,
			var(--color-primary-dark) 0%,
			var(--color-primary) 56%,
			color-mix(in srgb, var(--color-primary-light) 70%, white) 100%
		);
		color: white;
		box-shadow:
			0 18px 40px rgba(37, 99, 235, 0.2),
			inset 0 1px 0 rgba(255, 255, 255, 0.2);
		cursor: pointer;
		transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
	}

	.article-level-trigger:hover {
		transform: translateY(-1px);
		box-shadow:
			0 22px 44px rgba(37, 99, 235, 0.24),
			inset 0 1px 0 rgba(255, 255, 255, 0.26);
		filter: saturate(1.06);
	}

	.article-level-trigger:focus-visible {
		outline: 3px solid color-mix(in srgb, var(--color-primary-light) 68%, white);
		outline-offset: 3px;
	}

	.article-level-trigger:disabled {
		cursor: progress;
	}

	.article-level-trigger-copy {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		justify-content: center;
		gap: 0;
		min-width: 0;
	}

	.article-level-current {
		font-size: 1rem;
		font-weight: 700;
		color: white;
		letter-spacing: 0.01em;
	}

	.article-level-chevron {
		flex: none;
		color: rgba(255, 255, 255, 0.86);
		transition: transform 0.18s ease;
	}

	.article-level-menu {
		position: absolute;
		z-index: 3;
		left: 0;
		right: 0;
		top: calc(100% + 0.55rem);
		display: grid;
		gap: 0.35rem;
		padding: 0.4rem;
		border: 1px solid color-mix(in srgb, var(--color-primary-light) 26%, var(--color-border));
		border-radius: 16px;
		background: color-mix(in srgb, var(--color-bg-card) 96%, transparent);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		box-shadow:
			0 20px 42px rgba(15, 23, 42, 0.16),
			0 10px 26px rgba(37, 99, 235, 0.1);
		transform-origin: top center;
		animation: article-level-menu-in 0.18s ease-out;
	}

	.article-level-menu[hidden] {
		display: none;
	}

	.article-level-option {
		display: flex;
		align-items: center;
		width: 100%;
		min-height: 46px;
		padding: 0.75rem 0.85rem;
		border: 1px solid transparent;
		border-radius: 12px;
		background: transparent;
		color: var(--color-text);
		font: inherit;
		font-weight: 600;
		text-align: left;
		cursor: pointer;
		transition: background-color 0.18s ease, border-color 0.18s ease, color 0.18s ease;
	}

	.article-level-option:hover,
	.article-level-option:focus-visible {
		background: color-mix(in srgb, var(--color-primary) 10%, var(--color-bg-card));
		border-color: color-mix(in srgb, var(--color-primary-light) 28%, var(--color-border));
		color: var(--color-text-heading);
		outline: none;
	}

	.article-level-option.active {
		background: linear-gradient(
			135deg,
			var(--color-primary-dark) 0%,
			var(--color-primary) 56%,
			color-mix(in srgb, var(--color-primary-light) 72%, white) 100%
		);
		border-color: transparent;
		color: white;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.14);
	}

	.article-level-shell.is-open .article-level-chevron {
		transform: rotate(180deg);
	}

	.article-level-shell.is-compact .article-level-card {
		gap: 0.35rem;
	}

	.article-level-shell.is-compact .article-level-eyebrow {
		opacity: 0;
		transform: translateY(-4px);
		max-height: 0;
		overflow: hidden;
	}

	.article-level-shell.is-compact .article-level-trigger {
		min-height: 46px;
		padding-block: 0.75rem;
		box-shadow:
			0 14px 30px rgba(37, 99, 235, 0.18),
			inset 0 1px 0 rgba(255, 255, 255, 0.18);
	}

	.article-level-shell.is-loading .article-level-trigger {
		filter: saturate(0.92);
	}

	@keyframes article-level-menu-in {
		from {
			opacity: 0;
			transform: translateY(-6px) scale(0.98);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	@keyframes article-level-scrim-in {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	@media (max-width: 768px) {
		.article-level-shell {
			top: calc(var(--header-height) + 0.65rem);
			margin-bottom: 1.25rem;
		}

		.article-level-card {
			width: 100%;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.article-level-card,
		.article-level-eyebrow,
		.article-level-trigger,
		.article-level-chevron,
		.article-level-option {
			transition: none;
		}

		.article-level-menu {
			animation: none;
		}

		.article-level-scrim {
			animation: none;
		}
	}
</style>

<script is:inline>
	(() => {
		const init = () => {
			const root = document.querySelector('[data-article-level-switcher]');
			const prose = document.querySelector('[data-article-level-target]');

			if (!(root instanceof HTMLElement) || !(prose instanceof HTMLElement)) {
				return;
			}

			const trigger = root.querySelector('[data-article-level-trigger]');
			const current = root.querySelector('[data-article-level-current]');
			const menu = root.querySelector('[data-article-level-menu]');
			const scrim = root.querySelector('[data-article-level-scrim]');
			const options = Array.from(root.querySelectorAll('[data-article-level-option]'));

			if (
				!(trigger instanceof HTMLButtonElement) ||
				!(current instanceof HTMLElement) ||
				!(menu instanceof HTMLElement) ||
				!(scrim instanceof HTMLButtonElement) ||
				options.length === 0
			) {
				return;
			}

			const card = root.querySelector('.article-level-card');

			if (!(card instanceof HTMLElement)) {
				return;
			}

			const article = prose.closest('[data-article-level-article]');
			const toc = article instanceof HTMLElement ? article.querySelector('[data-article-level-toc]') : null;
			const tocNav = toc instanceof HTMLElement ? toc.querySelector('[data-article-level-toc-nav]') : null;
			const tocList = toc instanceof HTMLElement ? toc.querySelector('[data-article-level-toc-list]') : null;

				const routes = JSON.parse(root.dataset.articleLevelRoutes || '{}');
				const storageKey = root.dataset.articleLevelStorageKey || 'preferred-article-level';
				const defaultLevel = root.dataset.articleDefaultLevel || 'standard';
			const labels = Object.fromEntries(
				options.map((option) => [option.getAttribute('data-level'), option.textContent?.trim() ?? '']),
			);
				const cache = {
					standard: prose.innerHTML,
				};

			let activeLevel = defaultLevel;
			let requestToken = 0;
			let lastScrollY = window.scrollY;
			let frame = 0;
			let rootDocumentTop = 0;
			let tocDocumentBottom = 0;

			const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const dockGap = 24;
			const dockViewportPadding = 20;
			const dockViewportMinWidth = 1200;
			const compactThreshold = 0.72;

				const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

				const allowedProtocols = new Set(['http:', 'https:', 'mailto:', 'tel:']);
				const blockedSelectors = [
					'script',
					'style',
					'iframe',
					'object',
					'embed',
					'form',
					'input',
					'button',
					'textarea',
					'select',
					'meta',
					'base',
				].join(',');

				const isSafeUrl = (value) => {
					const trimmed = value.trim();

					if (!trimmed || trimmed.startsWith('#') || trimmed.startsWith('/')) {
						return true;
					}

					try {
						const parsed = new URL(trimmed, window.location.origin);
						return allowedProtocols.has(parsed.protocol);
					} catch {
						return false;
					}
				};

				const sanitizeHtml = (html) => {
					const parser = new DOMParser();
					const doc = parser.parseFromString(html, 'text/html');

					doc.querySelectorAll(blockedSelectors).forEach((node) => node.remove());

					doc.body.querySelectorAll('*').forEach((element) => {
						Array.from(element.attributes).forEach((attribute) => {
							const name = attribute.name.toLowerCase();
							const value = attribute.value;

							if (name.startsWith('on') || name === 'srcdoc' || name === 'formaction') {
								element.removeAttribute(attribute.name);
								return;
							}

							if (name === 'target' && value === '_blank') {
								const relTokens = new Set(
									(element.getAttribute('rel') || '')
										.split(/\s+/)
										.filter(Boolean),
								);
								relTokens.add('noopener');
								relTokens.add('noreferrer');
								element.setAttribute('rel', Array.from(relTokens).join(' '));
								return;
							}

							if ((name === 'href' || name === 'src' || name === 'poster' || name === 'xlink:href') && !isSafeUrl(value)) {
								element.removeAttribute(attribute.name);
							}
						});
					});

					return doc.body.innerHTML;
				};

				const replaceProseHtml = (html) => {
					const parser = new DOMParser();
					const doc = parser.parseFromString(html, 'text/html');
					const fragment = document.createDocumentFragment();

					Array.from(doc.body.childNodes).forEach((node) => {
						fragment.append(node.cloneNode(true));
					});

					prose.replaceChildren(fragment);
				};

				const getHeaderHeight = () =>
					parseInt(getComputedStyle(document.documentElement).getPropertyValue('--header-height') || '60', 10);

			const getStaticDocumentTop = (element) => {
				let top = 0;
				let current = element;

				while (current instanceof HTMLElement) {
					top += current.offsetTop;
					current = current.offsetParent;
				}

				return top;
			};

			const setOpen = (isOpen) => {
				root.classList.toggle('is-open', isOpen);
				trigger.setAttribute('aria-expanded', String(isOpen));
				menu.hidden = !isOpen;
				scrim.hidden = !isOpen;
			};

			const setActiveLevel = (level) => {
				activeLevel = level;
				const levelLabel = labels[level] || labels.standard || '標準';
				current.textContent = levelLabel;
				trigger.setAttribute('aria-label', `解説レベル: ${levelLabel}`);

				options.forEach((option) => {
					const isActive = option.getAttribute('data-level') === level;
					option.classList.toggle('active', isActive);
					option.setAttribute('aria-pressed', String(isActive));
				});
			};

			const extractHeadings = (html) => {
				const parser = new DOMParser();
				const doc = parser.parseFromString(html, 'text/html');
				return Array.from(doc.querySelectorAll('h2[id], h3[id]'))
					.map((heading) => {
						if (!(heading instanceof HTMLElement)) {
							return null;
						}

						return {
							depth: Number(heading.tagName.slice(1)),
							slug: heading.id,
							text: heading.textContent?.trim() ?? '',
						};
					})
					.filter((heading) => heading && heading.slug && heading.text);
			};

			const updateToc = (html) => {
				if (!(toc instanceof HTMLDetailsElement) || !(tocNav instanceof HTMLElement) || !(tocList instanceof HTMLElement)) {
					return;
				}

				const headings = extractHeadings(html).filter((heading) => heading.depth === 2 || heading.depth === 3);
				const wasOpen = toc.open;

				if (headings.length === 0) {
					toc.hidden = true;
					tocNav.hidden = true;
					tocList.replaceChildren();
					return;
				}

				const fragment = document.createDocumentFragment();

				headings.forEach((heading) => {
					const item = document.createElement('li');
					if (heading.depth === 3) {
						item.classList.add('toc-h3');
					}

					const link = document.createElement('a');
					link.href = `#${heading.slug}`;
					link.textContent = heading.text;
					item.append(link);
					fragment.append(item);
				});

				tocList.replaceChildren(fragment);
				toc.hidden = false;
				tocNav.hidden = false;
				toc.open = wasOpen;
			};

			const measureLayout = () => {
				rootDocumentTop = getStaticDocumentTop(root);

				if (toc instanceof HTMLElement) {
					const tocTop = getStaticDocumentTop(toc);
					tocDocumentBottom = tocTop + toc.offsetHeight;
				}
			};

			const getDesktopRailMetrics = () => {
				if (!(article instanceof HTMLElement) || window.innerWidth < dockViewportMinWidth) {
					return null;
				}

				const shellRect = root.getBoundingClientRect();
				const articleRect = article.getBoundingClientRect();
				const cardWidth = card.offsetWidth;
				const baseLeft = shellRect.left + Math.max((root.clientWidth - cardWidth) / 2, 0);
				const preferredLeft = articleRect.right + dockGap;
				const maxLeft = window.innerWidth - cardWidth - dockViewportPadding;

				if (preferredLeft > maxLeft) {
					return null;
				}

				return {
					baseLeft,
					targetLeft: preferredLeft,
				};
			};

			const getDesktopProgress = (railMetrics) => {
				if (!railMetrics || !(toc instanceof HTMLElement)) {
					return 0;
				}

				const headerHeight = getHeaderHeight();
				const start = Math.max(rootDocumentTop - headerHeight - 20, 0);
				const end = Math.max(tocDocumentBottom - headerHeight - 180, start + 1);

				return clamp((window.scrollY - start) / (end - start), 0, 1);
			};

			const setCompact = (progress) => {
				const headerHeight = getHeaderHeight();
				const proseTop = prose.getBoundingClientRect().top;
				const shouldCompact =
					window.innerWidth < 769
						? window.scrollY > 0 && proseTop <= headerHeight + 90
						: progress >= compactThreshold;

				root.classList.toggle('is-compact', shouldCompact);
			};

			const updateMotion = () => {
				const railMetrics = getDesktopRailMetrics();
				const desktopRailEnabled = Boolean(railMetrics);
				const desktopDockDisabled = window.innerWidth >= 769 && !desktopRailEnabled;
				const progress = getDesktopProgress(railMetrics);
				const scale = desktopRailEnabled ? 1 - progress * 0.12 : 1;
				const shiftY = desktopRailEnabled ? -6 * progress : 0;

				root.classList.toggle('is-dock-disabled', desktopDockDisabled);
				root.style.setProperty('--article-level-progress', progress.toFixed(3));
				root.style.setProperty('--article-level-scale', scale.toFixed(3));
				root.style.setProperty('--article-level-shift-y', `${shiftY.toFixed(2)}px`);

				let shiftX = 0;

				if (railMetrics && progress > 0) {
					shiftX = railMetrics.targetLeft - railMetrics.baseLeft;
				}

				root.style.setProperty('--article-level-shift-x', `${shiftX.toFixed(2)}px`);
				root.setAttribute(
					'data-article-level-placement',
					railMetrics && progress > 0 ? 'right-rail' : 'inline',
				);
				setCompact(progress);

				if (root.classList.contains('is-open') && Math.abs(window.scrollY - lastScrollY) > 3) {
					setOpen(false);
				}

				lastScrollY = window.scrollY;
			};

			const queueUpdateMotion = () => {
				if (frame) {
					return;
				}

				frame = window.requestAnimationFrame(() => {
					frame = 0;
					updateMotion();
				});
			};

				const animateSwap = (html) => {
					if (prefersReducedMotion) {
						replaceProseHtml(html);
						updateToc(html);
						measureLayout();
						queueUpdateMotion();
					return;
				}

				prose.classList.remove('is-level-switching-in');
					prose.classList.add('is-level-switching-out');

					window.setTimeout(() => {
						replaceProseHtml(html);
						updateToc(html);
						measureLayout();
						prose.classList.remove('is-level-switching-out');
					prose.classList.add('is-level-switching-in');
					queueUpdateMotion();

					window.setTimeout(() => {
						prose.classList.remove('is-level-switching-in');
					}, 240);
				}, 120);
			};

			const fetchLevel = async (level) => {
				if (cache[level]) {
					return cache[level];
				}

					const route = routes[level];

					if (!route) {
						throw new Error(`Missing article level route for ${level}`);
					}

					const routeUrl = new URL(route, window.location.origin);

					if (routeUrl.origin !== window.location.origin || !routeUrl.pathname.startsWith('/article-levels/')) {
						throw new Error(`Rejected article level route for ${level}`);
					}

					const response = await fetch(routeUrl, {
						headers: { 'X-Requested-With': 'article-level-switcher' },
					});

				if (!response.ok) {
					throw new Error(`Failed to fetch article level ${level}`);
				}

					const html = sanitizeHtml(await response.text());
					cache[level] = html;
					return html;
				};

			const prefetchAdditionalLevels = () => {
				Object.keys(routes).forEach((level) => {
					void fetchLevel(level).catch(() => {
						// Quietly keep the current prose if a variant payload is unavailable.
					});
				});
			};

			const switchLevel = async (level) => {
				if (level === activeLevel) {
					setOpen(false);
					return;
				}

				const nextToken = requestToken + 1;
				requestToken = nextToken;
				root.classList.add('is-loading');
				trigger.disabled = true;
				setOpen(false);

				try {
					const html = level === 'standard' ? cache.standard : await fetchLevel(level);

					if (requestToken !== nextToken) {
						return;
					}

					animateSwap(html);
					setActiveLevel(level);
					queueUpdateMotion();

					try {
						localStorage.setItem(storageKey, level);
					} catch {}
				} catch (error) {
					console.error(error);
				} finally {
					if (requestToken === nextToken) {
						root.classList.remove('is-loading');
						trigger.disabled = false;
					}
				}
			};

			const restorePreference = () => {
				try {
					const saved = localStorage.getItem(storageKey);
					if (!saved || saved === 'standard' || !routes[saved]) {
						return;
					}

					void fetchLevel(saved)
						.then((html) => {
							animateSwap(html);
							setActiveLevel(saved);
							queueUpdateMotion();
						})
						.catch(() => {
							// Stay on standard if the restore target is unavailable.
						});
				} catch {}
			};

			setActiveLevel(defaultLevel);
			setOpen(false);
			updateToc(cache.standard);
			measureLayout();
			queueUpdateMotion();

			trigger.addEventListener('click', () => {
				setOpen(!root.classList.contains('is-open'));
			});

			scrim.addEventListener('click', () => {
				setOpen(false);
			});

			options.forEach((option) => {
				option.addEventListener('click', () => {
					const nextLevel = option.getAttribute('data-level');
					if (!nextLevel) {
						return;
					}
					void switchLevel(nextLevel);
				});
			});

			document.addEventListener('click', (event) => {
				if (!root.contains(event.target)) {
					setOpen(false);
				}
			});

			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					setOpen(false);
				}
			});

			window.addEventListener('scroll', queueUpdateMotion, { passive: true });
			window.addEventListener('resize', () => {
				measureLayout();
				queueUpdateMotion();
			});
			window.addEventListener('load', () => {
				measureLayout();
				queueUpdateMotion();
			});
			if (toc instanceof HTMLDetailsElement) {
				toc.addEventListener('toggle', () => {
					measureLayout();
					queueUpdateMotion();
				});
			}

			if ('requestIdleCallback' in window) {
				window.requestIdleCallback(prefetchAdditionalLevels, { timeout: 1600 });
			} else {
				window.setTimeout(prefetchAdditionalLevels, 250);
			}

			restorePreference();
		};

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', init, { once: true });
		} else {
			init();
		}
	})();
</script>
