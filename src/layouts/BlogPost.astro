---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import GenerativeHero from '../components/GenerativeHero.astro';
import Header from '../components/Header.astro';
import AdSense from '../components/AdSense.astro';
import BackToTop from '../components/BackToTop.astro';
import ReadingTime from '../components/ReadingTime.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import TOC from '../components/TOC.astro';
import { SITE_TITLE } from '../consts';
import ArticleLevelSwitcher from '../components/ArticleLevelSwitcher.astro';
import { articleJsonLd, breadcrumbJsonLd } from '../utils/jsonld';
import { hasArticleLevelSwitcher, type ArticleLevelAvailability } from '../utils/articleLevels';
import { getCategoryLabel, getCategoryPath } from '../utils/categories';

type Props = CollectionEntry<'blog'>['data'] & {
	id?: string;
	headings?: Array<{ depth: number; slug: string; text: string }>;
	rawContent?: string;
	articleLevels?: ArticleLevelAvailability;
};

const { title, description, pubDate, updatedDate, heroImage, category, tags, id, headings, rawContent } =
	Astro.props;
const articleLevels = Astro.props.articleLevels ?? {};

const siteUrl = Astro.site?.toString() ?? '';
const articleUrl = `${siteUrl}blog/${id}/`;
const categoryLabel = getCategoryLabel(category);
const categoryPath = getCategoryPath(category);
const showArticleLevelSwitcher = id ? hasArticleLevelSwitcher(articleLevels) : false;

const articleLd = articleJsonLd({
	title,
	description,
	pubDate,
	updatedDate,
	url: articleUrl,
});

const breadcrumbLd = breadcrumbJsonLd([
	{ name: 'ホーム', url: siteUrl },
	{ name: 'ブログ', url: `${siteUrl}blog/` },
	{ name: categoryLabel, url: `${siteUrl}${categoryPath.replace(/^\//, '')}` },
	{ name: title, url: articleUrl },
]);
---

<html lang="ja">
	<head>
		<BaseHead title={`${title} | ${SITE_TITLE}`} description={description} type="article" />
		<script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
	</head>

	<body>
		<Header />
		<main>
			<article data-article-level-article>
				<div class="hero-image">
					<GenerativeHero seed={title} alt={title} loading="eager" />
				</div>
				<div class="article-header">
					<div class="meta">
						<a href={categoryPath} class="category-badge">{categoryLabel}</a>
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="updated">
									(更新: <FormattedDate date={updatedDate} />)
								</span>
							)
						}
					{rawContent && <ReadingTime content={rawContent} />}
					</div>
					<h1>{title}</h1>
					{
						tags && tags.length > 0 && (
							<div class="tags">
								{tags.map((tag) => (
									<span class="tag">#{tag}</span>
								))}
							</div>
						)
					}
				</div>

				{showArticleLevelSwitcher && id && <ArticleLevelSwitcher articleId={id} availability={articleLevels} />}

				{headings && headings.length > 0 && <TOC headings={headings} />}

				<AdSense label="記事上" format="horizontal" />

				<div class="prose" data-article-level-target>
					<slot />
				</div>

				<AdSense label="記事下" format="rectangle" />

				<RelatedPosts currentId={id ?? ''} category={category} tags={tags ?? []} />
			</article>
		</main>
		<BackToTop />
		<Footer />
	</body>
</html>

<style>
	main {
		width: var(--max-width);
		max-width: calc(100% - 2rem);
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	.hero-image {
		margin-bottom: 2rem;
	}

	.hero-image img {
		width: 100%;
		height: auto;
		border-radius: 12px;
	}

	.article-header {
		margin-bottom: 2rem;
	}

	.meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.75rem;
		font-size: 0.875rem;
		color: var(--color-text-muted);
		flex-wrap: wrap;
	}

	.category-badge {
		display: inline-block;
		padding: 0.2em 0.6em;
		background-color: rgba(59, 130, 246, 0.15);
		color: var(--color-primary-light);
		border-radius: 4px;
		font-size: 0.8rem;
		font-weight: 600;
		text-decoration: none;
	}

	.category-badge:hover {
		background-color: rgba(59, 130, 246, 0.25);
		text-decoration: none;
	}

	.updated {
		font-style: italic;
		font-size: 0.8rem;
	}

	h1 {
		font-size: 1.8rem;
		line-height: 1.4;
		margin-bottom: 0.75rem;
	}

	.tags {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.tag {
		color: var(--color-text-muted);
		font-size: 0.8rem;
	}

	.prose {
		line-height: 1.9;
		transition: opacity 0.18s ease, transform 0.24s ease;
	}

	.prose :global(h2) {
		margin-top: 3rem;
	}

	.prose :global(img) {
		margin: 1.5rem 0;
	}

	.prose.is-level-switching-out {
		opacity: 0.24;
		transform: translateY(-6px);
	}

	.prose.is-level-switching-in {
		animation: article-level-prose-in 0.24s ease;
	}

	@keyframes article-level-prose-in {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 768px) {
		h1 {
			font-size: 1.4rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.prose {
			transition: none;
		}

		.prose.is-level-switching-in {
			animation: none;
		}
	}
</style>
