---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import GenerativeHero from '../components/GenerativeHero.astro';
import Header from '../components/Header.astro';
import AdSense from '../components/AdSense.astro';
import BackToTop from '../components/BackToTop.astro';
import ReadingTime from '../components/ReadingTime.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import TOC from '../components/TOC.astro';
import { SITE_AUTHOR, SITE_AUTHOR_DESCRIPTION, GITHUB_URL, SITE_TITLE } from '../consts';
import ArticleLevelSwitcher from '../components/ArticleLevelSwitcher.astro';
import { articleJsonLd, breadcrumbJsonLd } from '../utils/jsonld';
import { hasArticleLevelSwitcher, type ArticleLevelAvailability } from '../utils/articleLevels';
import { getCategoryLabel } from '../utils/categories';
import { getTagPath } from '../utils/tags';

type Props = CollectionEntry<'blog'>['data'] & {
	id?: string;
	headings?: Array<{ depth: number; slug: string; text: string }>;
	rawContent?: string;
	articleLevels?: ArticleLevelAvailability;
};

const { title, description, pubDate, updatedDate, heroImage, category, tags, id, headings, rawContent } =
	Astro.props;
const articleLevels = Astro.props.articleLevels ?? {};

const siteUrl = Astro.site?.toString() ?? '';
const articleUrl = `${siteUrl}blog/${id}/`;
const categoryLabel = getCategoryLabel(category);
const showArticleLevelSwitcher = id ? hasArticleLevelSwitcher(articleLevels) : false;

const articleLd = articleJsonLd({
	title,
	description,
	pubDate,
	updatedDate,
	url: articleUrl,
});

const breadcrumbLd = breadcrumbJsonLd([
	{ name: 'ホーム', url: siteUrl },
	{ name: 'ブログ', url: `${siteUrl}blog/` },
	{ name: title, url: articleUrl },
]);
---

<html lang="ja">
	<head>
		<BaseHead title={`${title} | ${SITE_TITLE}`} description={description} type="article" />
		<script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
	</head>

	<body>
		<Header />
		<main>
			<article data-article-level-article>
				<div class="hero-image">
					<GenerativeHero seed={title} alt={title} loading="eager" />
				</div>
				<div class="article-header">
					<div class="meta">
						<span class="category-badge">{categoryLabel}</span>
						<a href="/about" class="author-link">{SITE_AUTHOR}</a>
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="updated">
									(更新: <FormattedDate date={updatedDate} />)
								</span>
							)
						}
						{rawContent && <ReadingTime content={rawContent} />}
					</div>
					<h1>{title}</h1>
					{
						tags && tags.length > 0 && (
							<div class="tags">
								{tags.map((tag) => (
									<a href={getTagPath(tag)} class="tag">#{tag}</a>
								))}
							</div>
						)
					}
				</div>

				{showArticleLevelSwitcher && id && <ArticleLevelSwitcher articleId={id} availability={articleLevels} />}

				{headings && headings.length > 0 && <TOC headings={headings} />}

				<AdSense label="記事上" format="horizontal" />

				<div class="prose" data-article-level-target>
					<slot />
				</div>

				<AdSense label="記事下" format="rectangle" />

				<section class="article-trust-box" aria-label="記事制作情報">
					<p class="trust-eyebrow">Who / How / Why</p>
					<h2>この記事について</h2>
					<p class="trust-copy">
						執筆者は {SITE_AUTHOR}。{SITE_AUTHOR_DESCRIPTION}
						このサイトでは、公式ブログ、公式ドキュメント、changelog、論文などの一次ソースを優先し、その内容を日本の開発者・事業担当者向けに整理しています。
					</p>
					<ul class="trust-list">
						<li>一次ソース優先で事実確認</li>
						<li>日本市場と実務への影響を追加で分析</li>
						<li>誤りの指摘はお問い合わせから受付</li>
					</ul>
					<div class="trust-links">
						<a href="/about">運営者情報</a>
						<a href="/editorial-policy">編集方針</a>
						<a href="/contact">訂正・お問い合わせ</a>
						<a href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a>
					</div>
				</section>

				<RelatedPosts currentId={id ?? ''} tags={tags ?? []} />
			</article>
		</main>
		<BackToTop />
		<Footer />
	</body>
</html>

<style>
	main {
		width: var(--max-width);
		max-width: calc(100% - 2rem);
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	.hero-image {
		margin-bottom: 2rem;
	}

	.hero-image img {
		width: 100%;
		height: auto;
		border-radius: 12px;
	}

	.article-header {
		margin-bottom: 2rem;
	}

	.meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.75rem;
		font-size: 0.875rem;
		color: var(--color-text-muted);
		flex-wrap: wrap;
	}

	.category-badge {
		display: inline-block;
		padding: 0.2em 0.6em;
		background-color: rgba(59, 130, 246, 0.15);
		color: var(--color-primary-light);
		border-radius: 4px;
		font-size: 0.8rem;
		font-weight: 600;
	}

	.author-link {
		color: var(--color-text-muted);
		text-decoration: none;
		font-weight: 600;
	}

	.author-link:hover {
		color: var(--color-primary-light);
		text-decoration: none;
	}

	.updated {
		font-style: italic;
		font-size: 0.8rem;
	}

	h1 {
		font-size: 1.8rem;
		line-height: 1.4;
		margin-bottom: 0.75rem;
	}

	.tags {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.tag {
		display: inline-block;
		color: var(--color-text-muted);
		font-size: 0.8rem;
		text-decoration: none;
	}

	.tag:hover {
		color: var(--color-primary-light);
		text-decoration: none;
	}

	.prose {
		line-height: 1.9;
		transition: opacity 0.18s ease, transform 0.24s ease;
	}

	.prose :global(h2) {
		margin-top: 3rem;
	}

	.prose :global(img) {
		margin: 1.5rem 0;
	}

	.article-trust-box {
		margin-top: 2rem;
		padding: 1.25rem;
		border: 1px solid var(--color-border);
		border-radius: 14px;
		background: color-mix(in srgb, var(--color-bg-card) 88%, transparent);
	}

	.article-trust-box h2 {
		font-size: 1.1rem;
		margin: 0.25rem 0 0.75rem;
	}

	.trust-eyebrow {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	.trust-copy {
		margin-bottom: 0.85rem;
		color: var(--color-text-muted);
	}

	.trust-list {
		margin: 0 0 1rem;
		padding-left: 1.2rem;
	}

	.trust-list li {
		margin-bottom: 0.4rem;
	}

	.trust-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.trust-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.45rem 0.7rem;
		border-radius: 999px;
		background: rgba(59, 130, 246, 0.08);
		font-size: 0.85rem;
		text-decoration: none;
	}

	.prose.is-level-switching-out {
		opacity: 0.24;
		transform: translateY(-6px);
	}

	.prose.is-level-switching-in {
		animation: article-level-prose-in 0.24s ease;
	}

	@keyframes article-level-prose-in {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 768px) {
		h1 {
			font-size: 1.4rem;
		}

		.article-trust-box {
			padding: 1rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.prose {
			transition: none;
		}

		.prose.is-level-switching-in {
			animation: none;
		}
	}
</style>
