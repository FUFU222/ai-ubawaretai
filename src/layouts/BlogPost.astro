---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import BlogSidebar from '../components/BlogSidebar.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import GenerativeHero from '../components/GenerativeHero.astro';
import Header from '../components/Header.astro';
import AdSense from '../components/AdSense.astro';
import BackToTop from '../components/BackToTop.astro';
import ReadingTime from '../components/ReadingTime.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import SeriesNav from '../components/SeriesNav.astro';
import TOC from '../components/TOC.astro';
import { SITE_AUTHOR, SITE_TITLE } from '../consts';
import ArticleLevelSwitcher from '../components/ArticleLevelSwitcher.astro';
import { articleJsonLd, breadcrumbJsonLd } from '../utils/jsonld';
import { hasArticleLevelSwitcher, type ArticleLevelAvailability } from '../utils/articleLevels';
import { getCategoryLabel } from '../utils/categories';
import { getPrimaryTag, getTagPath } from '../utils/tags';
import { extractSourceLinks } from '../utils/source-links';
import { getSeriesForPost } from '../utils/series';

type Props = CollectionEntry<'blog'>['data'] & {
	id?: string;
	headings?: Array<{ depth: number; slug: string; text: string }>;
	rawContent?: string;
	articleLevels?: ArticleLevelAvailability;
	indexableTags?: string[];
};

const { title, description, pubDate, updatedDate, heroImage, category, tags, id, headings, rawContent } =
	Astro.props;
const articleLevels = Astro.props.articleLevels ?? {};
const indexableTagSet = new Set(Astro.props.indexableTags ?? tags ?? []);

const siteUrl = Astro.site?.toString() ?? '';
const articleUrl = `${siteUrl}blog/${id}/`;
const categoryLabel = getCategoryLabel(category);
const hasPrimaryTag = Boolean(tags && tags.length > 0);
const primaryTag = getPrimaryTag(tags ?? []);
const taxonomyLabel = hasPrimaryTag ? primaryTag : categoryLabel;
const taxonomyPath = hasPrimaryTag && indexableTagSet.has(primaryTag) ? getTagPath(primaryTag) : '/category/';
const taxonomyBadgeLabel = hasPrimaryTag ? `#${primaryTag}` : categoryLabel;
const showArticleLevelSwitcher = id ? hasArticleLevelSwitcher(articleLevels) : false;
const displayUpdatedDate = updatedDate ?? pubDate;
const sourceLinks = extractSourceLinks(rawContent ?? '');
const allPublishedPosts = await getCollection('blog', ({ data }) => !data.draft);
const currentPost = id ? allPublishedPosts.find((post) => post.id === id) : undefined;
const currentSeries = currentPost ? getSeriesForPost(currentPost, allPublishedPosts) : undefined;
const hasSeriesNav = Boolean(currentSeries && currentSeries.posts.length > 1);
const hasArticleLevelControl = Boolean(showArticleLevelSwitcher && id);
const hasRightRail = hasArticleLevelControl || hasSeriesNav;

const articleLd = articleJsonLd({
	title,
	description,
	pubDate,
	updatedDate,
	url: articleUrl,
});

const breadcrumbLd = breadcrumbJsonLd([
	{ name: 'ホーム', url: siteUrl },
	{ name: 'ブログ', url: `${siteUrl}blog/` },
	{ name: taxonomyLabel, url: `${siteUrl}${taxonomyPath.replace(/^\//, '')}` },
	{ name: title, url: articleUrl },
]);
---

<html lang="ja">
		<head>
			<BaseHead
				title={`${title} | ${SITE_TITLE}`}
				description={description}
				type="article"
				includeAdNetwork={true}
			/>
			<script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
			<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
		</head>

	<body>
		<Header />
		<main>
			<article data-article-level-article>
				<div class="article-header article-brief">
					<p class="article-eyebrow">Article Brief</p>
					<div class="meta">
						<a href={taxonomyPath} class="category-badge">{taxonomyBadgeLabel}</a>
						<a href="/about" class="author-link">{SITE_AUTHOR}</a>
						<span class="meta-label">公開: <FormattedDate date={pubDate} /></span>
						<span class="meta-label">更新: <FormattedDate date={displayUpdatedDate} /></span>
						{rawContent && <ReadingTime content={rawContent} />}
					</div>
					<h1>{title}</h1>
					{
						tags && tags.length > 0 && (
							<div class="tags">
								{tags.map((tag) => (
									indexableTagSet.has(tag) ? (
										<a href={getTagPath(tag)} class="tag">#{tag}</a>
									) : (
										<span class="tag tag-static">#{tag}</span>
									)
								))}
							</div>
						)
					}
				</div>
				<div class="hero-image">
					<GenerativeHero seed={title} alt={title} loading="eager" />
				</div>

				<div class:list={['article-shell', { 'has-right-rail': hasRightRail }]}>
					<div class="article-primary">
						{headings && headings.length > 0 && <TOC headings={headings} />}

						<AdSense label="記事上" format="horizontal" />

						<div class="prose" data-article-level-target>
							<slot />
						</div>

						<AdSense label="記事下" format="rectangle" />

						<section class="article-info-box" aria-label="記事情報">
							<p class="info-eyebrow">Article Info</p>
							<h2>記事情報</h2>
							<dl class="article-facts">
								<div>
									<dt>著者</dt>
									<dd><a href="/about">{SITE_AUTHOR}</a></dd>
								</div>
								<div>
									<dt>公開日</dt>
									<dd><FormattedDate date={pubDate} /></dd>
								</div>
								<div>
									<dt>更新日</dt>
									<dd><FormattedDate date={displayUpdatedDate} /></dd>
								</div>
							</dl>
							{
								sourceLinks.length > 0 && (
									<div class="source-section">
										<h3>出典リンク</h3>
										<ul class="source-link-list">
											{sourceLinks.map((source) => (
												<li>
													<a href={source.url} target="_blank" rel="noopener noreferrer">
														{source.label}
													</a>
												</li>
											))}
										</ul>
									</div>
								)
							}
							<div class="info-links">
								<a href="/about">About</a>
								<a href="/contact">訂正・お問い合わせ</a>
								<a href="/privacy">プライバシーポリシー</a>
							</div>
						</section>

						<RelatedPosts currentId={id ?? ''} tags={tags ?? []} category={category} />
					</div>

					{
						id && (
							<aside class="article-left-rail" aria-label="ブログ内を移動">
								<BlogSidebar currentId={id} tags={tags ?? []} category={category} posts={allPublishedPosts} />
							</aside>
						)
					}

					{
						hasArticleLevelControl && id && (
							<aside class="article-level-rail" aria-label="解説レベル">
								<ArticleLevelSwitcher articleId={id} availability={articleLevels} placement="rail" />
							</aside>
						)
					}

					{
						id && hasSeriesNav && (
							<aside class="article-right-rail" aria-label="シリーズ記事">
								<SeriesNav currentId={id} placement="sidebar" posts={allPublishedPosts} />
							</aside>
						)
					}
				</div>
			</article>
		</main>
		<BackToTop />
		<Footer />
	</body>
</html>

<style>
	main {
		width: min(var(--wide-width), calc(100% - 2rem));
		max-width: none;
		margin: 0 auto;
		padding: 2rem 0;
	}

	.article-header,
	.hero-image {
		width: min(var(--max-width), 100%);
		margin-left: auto;
		margin-right: auto;
	}

	.hero-image {
		margin-top: 0;
		margin-bottom: 2rem;
	}

	.article-shell {
		display: grid;
		grid-template-areas:
			'left main level'
			'left main right';
		grid-template-columns: minmax(12rem, 14.5rem) minmax(0, var(--max-width)) minmax(13rem, 16rem);
		grid-template-rows: auto 1fr;
		column-gap: 1.55rem;
		row-gap: 1.1rem;
		align-items: start;
		width: 100%;
		margin: 0 auto;
	}

	.article-primary {
		grid-area: main;
		min-width: 0;
	}

	.article-left-rail {
		grid-area: left;
	}

	.article-right-rail {
		grid-area: right;
	}

	.article-level-rail {
		grid-area: level;
	}

	.article-left-rail,
	.article-level-rail,
	.article-right-rail {
		min-width: 0;
		align-self: start;
	}

	.article-left-rail,
	.article-level-rail {
		position: sticky;
		top: calc(var(--header-height) + 1.2rem);
	}

	.article-left-rail {
		padding-right: 1.1rem;
		border-right: 1px solid color-mix(in srgb, var(--color-border) 74%, transparent);
	}

	.article-level-rail,
	.article-right-rail {
		padding-left: 1.1rem;
		border-left: 1px solid color-mix(in srgb, var(--color-border) 74%, transparent);
	}

	.article-right-rail {
		position: sticky;
		top: calc(var(--header-height) + 9.5rem);
	}

	.hero-image :global(img) {
		width: 100%;
		height: auto;
		border-radius: 8px;
	}

	.article-header {
		margin-bottom: 1.4rem;
		padding-bottom: 1.25rem;
		border-bottom: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
	}

	.article-eyebrow {
		margin: 0 0 0.45rem;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	.meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.75rem;
		font-size: 0.875rem;
		color: var(--color-text-muted);
		flex-wrap: wrap;
	}

	.category-badge {
		display: inline-block;
		padding: 0.2em 0.6em;
		background-color: color-mix(in srgb, #f59e0b 14%, transparent);
		color: #b45309;
		border-radius: 4px;
		font-size: 0.8rem;
		font-weight: 600;
	}

	.author-link {
		color: var(--color-text-muted);
		text-decoration: none;
		font-weight: 600;
	}

	.author-link:hover {
		color: var(--color-primary-light);
		text-decoration: none;
	}

	.updated {
		font-size: 0.8rem;
	}

	h1 {
		font-size: 1.8rem;
		line-height: 1.4;
		margin-bottom: 0.75rem;
	}

	.tags {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.tag {
		display: inline-block;
		color: var(--color-text-muted);
		font-size: 0.8rem;
		text-decoration: none;
	}

	.tag:hover {
		color: var(--color-primary-light);
		text-decoration: none;
	}

	.tag-static:hover {
		color: var(--color-text-muted);
	}

	.prose {
		line-height: 1.9;
		transition: opacity 0.18s ease, transform 0.24s ease;
	}

	.prose :global(h2) {
		margin-top: 3rem;
	}

	.prose :global(img) {
		margin: 1.5rem 0;
	}

	.article-info-box {
		margin-top: 2rem;
		padding: 1.25rem 0;
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.article-info-box h2 {
		font-size: 1.1rem;
		margin: 0.25rem 0 0.75rem;
	}

	.info-eyebrow {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	.meta-label {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
	}

	.article-facts {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 0.85rem;
		margin: 0 0 1rem;
	}

	.article-facts div {
		padding: 0.85rem 0;
		border-top: 1px solid color-mix(in srgb, var(--color-border) 78%, transparent);
	}

	.article-facts dt {
		margin: 0 0 0.35rem;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	.article-facts dd {
		margin: 0;
		color: var(--color-text-heading);
	}

	.article-facts a {
		color: inherit;
		text-decoration: none;
	}

	.article-facts a:hover {
		color: var(--color-primary-light);
	}

	.source-section h3 {
		margin-bottom: 0.75rem;
		font-size: 0.95rem;
	}

	.source-link-list {
		margin: 0 0 1rem;
		padding-left: 1.25rem;
	}

	.source-link-list li + li {
		margin-top: 0.5rem;
	}

	.source-link-list a {
		word-break: break-word;
	}

	.info-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.info-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.45rem 0.7rem;
		border: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
		border-radius: 8px;
		font-size: 0.85rem;
		text-decoration: none;
	}

	.prose.is-level-switching-out {
		opacity: 0.24;
		transform: translateY(-6px);
	}

	.prose.is-level-switching-in {
		animation: article-level-prose-in 0.24s ease;
	}

	@keyframes article-level-prose-in {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 768px) {
		h1 {
			font-size: 1.4rem;
		}

		.article-info-box {
			padding: 1rem;
		}
	}

	@media (max-width: 1139px) {
		main {
			width: var(--max-width);
			max-width: calc(100% - 2rem);
		}

		.article-shell {
			grid-template-areas:
				'level'
				'main'
				'left'
				'right';
			grid-template-columns: minmax(0, 1fr);
			gap: 2.2rem;
		}

		.article-left-rail,
		.article-level-rail,
		.article-right-rail {
			position: static;
			padding: 0;
			border: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.prose {
			transition: none;
		}

		.prose.is-level-switching-in {
			animation: none;
		}
	}
</style>
