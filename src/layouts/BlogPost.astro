---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import GenerativeHero from '../components/GenerativeHero.astro';
import Header from '../components/Header.astro';
import AdSense from '../components/AdSense.astro';
import TOC from '../components/TOC.astro';
import { CATEGORIES, SITE_TITLE } from '../consts';
import { articleJsonLd, breadcrumbJsonLd } from '../utils/jsonld';

type Props = CollectionEntry<'blog'>['data'] & {
	id?: string;
	headings?: Array<{ depth: number; slug: string; text: string }>;
};

const { title, description, pubDate, updatedDate, heroImage, category, tags, id, headings } =
	Astro.props;

const siteUrl = Astro.site?.toString() ?? '';
const articleUrl = `${siteUrl}blog/${id}/`;
const categoryLabel = CATEGORIES[category];

const articleLd = articleJsonLd({
	title,
	description,
	pubDate,
	updatedDate,
	url: articleUrl,
});

const breadcrumbLd = breadcrumbJsonLd([
	{ name: 'ホーム', url: siteUrl },
	{ name: 'ブログ', url: `${siteUrl}blog/` },
	{ name: categoryLabel, url: `${siteUrl}category/${category}/` },
	{ name: title, url: articleUrl },
]);
---

<html lang="ja">
	<head>
		<BaseHead title={`${title} | ${SITE_TITLE}`} description={description} type="article" />
		<script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					<GenerativeHero seed={title} alt={title} loading="eager" />
				</div>
				<div class="article-header">
					<div class="meta">
						<a href={`/category/${category}/`} class="category-badge">{categoryLabel}</a>
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="updated">
									(更新: <FormattedDate date={updatedDate} />)
								</span>
							)
						}
					</div>
					<h1>{title}</h1>
					{
						tags && tags.length > 0 && (
							<div class="tags">
								{tags.map((tag) => (
									<span class="tag">#{tag}</span>
								))}
							</div>
						)
					}
				</div>

				{headings && headings.length > 0 && <TOC headings={headings} />}

				<AdSense label="記事上" format="horizontal" />

				<div class="prose">
					<slot />
				</div>

				<AdSense label="記事下" format="rectangle" />
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: var(--max-width);
		max-width: calc(100% - 2rem);
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	.hero-image {
		margin-bottom: 2rem;
	}

	.hero-image img {
		width: 100%;
		height: auto;
		border-radius: 12px;
	}

	.article-header {
		margin-bottom: 2rem;
	}

	.meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 0.75rem;
		font-size: 0.875rem;
		color: var(--color-text-muted);
		flex-wrap: wrap;
	}

	.category-badge {
		display: inline-block;
		padding: 0.2em 0.6em;
		background-color: rgba(59, 130, 246, 0.15);
		color: var(--color-primary-light);
		border-radius: 4px;
		font-size: 0.8rem;
		font-weight: 600;
		text-decoration: none;
	}

	.category-badge:hover {
		background-color: rgba(59, 130, 246, 0.25);
		text-decoration: none;
	}

	.updated {
		font-style: italic;
		font-size: 0.8rem;
	}

	h1 {
		font-size: 1.8rem;
		line-height: 1.4;
		margin-bottom: 0.75rem;
	}

	.tags {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.tag {
		color: var(--color-text-muted);
		font-size: 0.8rem;
	}

	.prose {
		line-height: 1.9;
	}

	.prose :global(h2) {
		margin-top: 3rem;
	}

	.prose :global(img) {
		margin: 1.5rem 0;
	}

	@media (max-width: 768px) {
		h1 {
			font-size: 1.4rem;
		}
	}
</style>
