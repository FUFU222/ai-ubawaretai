---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { GITHUB_URL, NOINDEX_ROBOTS, SITE_TITLE } from '../consts';

const contactDescription = '記事の内容に関するご連絡や、取材・掲載のご相談はこちらからお願いします。';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={`お問い合わせ | ${SITE_TITLE}`}
			description={contactDescription}
			robots={NOINDEX_ROBOTS}
		/>
	</head>
	<body>
		<Header />
		<main>
			<article class="contact">
				<h1>お問い合わせ</h1>
				<p class="lead">記事の内容に関するご連絡や、取材・掲載のご相談はこちらからお願いします。</p>

				<section>
					<h2>お問い合わせ方法</h2>
					<p>
							<a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">
							運営者のGitHubプロフィール
						</a>
						を公開しています。プロフィール経由でのご連絡や公開活動の確認が可能です。
					</p>
				</section>

				<section>
					<h2>このページで受け付ける内容</h2>
					<ul>
						<li>記事の内容に関する修正・訂正のご指摘</li>
						<li>記事の内容に関するご質問や出典の補足</li>
						<li>サイトの不具合のご報告</li>
						<li>取材・掲載に関するご相談</li>
						<li>その他のご質問・ご意見</li>
					</ul>
				</section>

				<section>
					<h2>訂正依頼について</h2>
					<p>
						記事URL、該当箇所、修正提案、根拠となるソースを添えてご連絡いただけると確認が早くなります。重要な事実誤認は優先して対応します。
					</p>
				</section>

				<p class="note">
					お問い合わせの内容によっては、返信や反映までにお時間をいただく場合があります。営業目的の一斉送信や不明瞭な依頼には回答しないことがあります。
				</p>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.contact h2 {
		font-size: 1.25rem;
		margin-top: 2rem;
	}

	.lead {
		font-size: 1rem;
		line-height: 1.9;
		color: var(--color-text-heading);
	}

	.contact ul {
		padding-left: 1.5em;
	}

	.note {
		margin-top: 3rem;
		color: var(--color-text-muted);
		font-size: 0.875rem;
	}
</style>
