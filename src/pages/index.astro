---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import GenerativeHero from '../components/GenerativeHero.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { personJsonLd, websiteJsonLd } from '../utils/jsonld';
import { getPrimaryTag, getTagPath, getTagSummaries } from '../utils/tags';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = [...allPosts]
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 8);
const featuredPost = posts[0];
const nextPosts = posts.slice(1, 5);
const latestPosts = posts.slice(0, 6);
const tagSummaries = getTagSummaries(allPosts)
	.filter((tag) => tag.isIndexable)
	.slice(0, 12);

const personLd = personJsonLd();
const websiteLd = websiteJsonLd();
---

<!doctype html>
<html lang="ja">
		<head>
			<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
			<script type="application/ld+json" set:html={JSON.stringify(personLd)} />
			<script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
		</head>
	<body>
		<Header />
		<main>
			<section class="radar-hero">
				<p class="radar-kicker">AI News Radar</p>
				<div class="radar-hero-grid">
					<div>
						<h1>{SITE_TITLE}</h1>
						<p class="radar-lead">
							いま追うべきAIニュースを、日本の開発現場と事業判断に引き寄せて読む。
						</p>
					</div>
					<div class="radar-actions" aria-label="主要導線">
						<a href="/blog">最新記事を読む</a>
						<a href="/category">テーマで追う</a>
					</div>
				</div>
			</section>

			<div class="home-shell">
				<div class="home-main-column">
					{
						featuredPost && (
							<section class="radar-board" aria-labelledby="first-read-title">
								<div class="section-heading">
									<p class="section-eyebrow">First Read</p>
									<h2 id="first-read-title">最初に読む</h2>
								</div>
								<div class="lead-layout">
									<a href={`/blog/${featuredPost.id}/`} class="featured-story">
										<div class="featured-image">
											<GenerativeHero seed={featuredPost.data.title} alt={featuredPost.data.title} />
										</div>
									</a>
									<div class="featured-copy">
										<CategoryBadge label={`#${getPrimaryTag(featuredPost.data.tags)}`} class="post-category-badge" />
										<h3>
											<a href={`/blog/${featuredPost.id}/`}>{featuredPost.data.title}</a>
										</h3>
										<p>{featuredPost.data.description}</p>
										<span>
											<FormattedDate date={featuredPost.data.pubDate} />
										</span>
									</div>
								</div>
							</section>
						)
					}

					<section class="latest-dispatch">
						<div class="section-heading with-link">
							<div>
								<p class="section-eyebrow">Latest</p>
								<h2>最新記事</h2>
							</div>
							<a href="/blog">記事一覧へ</a>
						</div>
						<div class="dispatch-list">
							{
								latestPosts.map((post) => (
									<a href={`/blog/${post.id}/`} class="dispatch-row">
										<span>
											<FormattedDate date={post.data.pubDate} />
										</span>
										<strong>{post.data.title}</strong>
									</a>
								))
							}
						</div>
					</section>
				</div>

				<aside class="home-left-rail" aria-label="カテゴリとトピック">
					<div class="section-heading with-link">
						<div>
							<p class="section-eyebrow">Topics</p>
							<h2>カテゴリ</h2>
						</div>
						<a href="/category">タグ一覧</a>
					</div>
					<div class="topic-list">
						{
							tagSummaries.map(({ slug, label, count }) => (
								<a href={getTagPath(slug)} class="topic-link">
									<span>{label}</span>
									<small>{count}件</small>
								</a>
							))
						}
					</div>
					<nav class="rail-shortcuts" aria-label="ブログ主要導線">
						<a href="/blog">記事一覧</a>
						<a href="/category">タグ一覧</a>
						<a href="/rss.xml">RSS</a>
					</nav>
				</aside>

				<aside class="home-right-rail" aria-label="おすすめ記事">
					<section class="next-reads" aria-labelledby="next-reads-title">
						<div class="section-heading compact">
							<p class="section-eyebrow">Recommended</p>
							<h2 id="next-reads-title">おすすめ記事</h2>
						</div>
						<div class="next-list">
							{nextPosts.map((post, index) => (
								<a href={`/blog/${post.id}/`} class="next-item">
									<span class="next-rank">{String(index + 1).padStart(2, '0')}</span>
									<span class="next-copy">
										<small>
											<FormattedDate date={post.data.pubDate} />
										</small>
										<strong>{post.data.title}</strong>
									</span>
								</a>
							))}
						</div>
					</section>
				</aside>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		--home-accent: #f59e0b;
		--home-desktop-width: 1280px;
		width: min(var(--home-desktop-width), calc(100% - 3rem));
		max-width: none;
		padding: 2.35rem 0;
	}

	.radar-hero {
		padding: 2rem 0 1.9rem;
		border-bottom: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
	}

	.radar-kicker,
	.section-eyebrow {
		margin: 0 0 0.45rem;
		color: var(--home-accent);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.radar-hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(12rem, auto);
		align-items: center;
		gap: 2rem;
	}

	.radar-hero h1 {
		margin: 0;
		font-size: clamp(1.7rem, 4vw, 2.35rem);
		letter-spacing: 0;
	}

	.radar-lead {
		max-width: 37rem;
		margin: 0.65rem 0 0;
		color: var(--color-text-muted);
		font-size: 0.98rem;
		line-height: 1.85;
	}

	.radar-actions {
		display: grid;
		gap: 0.55rem;
		min-width: 9rem;
	}

	.radar-actions a,
	.section-heading.with-link > a {
		color: var(--color-text-heading);
		font-size: 0.86rem;
		font-weight: 700;
		text-decoration: none;
	}

	.radar-actions a::after,
	.section-heading.with-link > a::after {
		content: ' ->';
		color: var(--home-accent);
	}

	.home-shell {
		margin-top: 2.25rem;
	}

	.home-shell {
		display: grid;
		grid-template-areas: 'left main right';
		grid-template-columns: minmax(12rem, 15rem) minmax(0, 1fr) minmax(15rem, 19rem);
		gap: 2rem;
		align-items: start;
	}

	.home-main-column {
		grid-area: main;
		min-width: 0;
	}

	.home-left-rail {
		grid-area: left;
	}

	.home-right-rail {
		grid-area: right;
	}

	.home-left-rail,
	.home-right-rail {
		position: sticky;
		top: calc(var(--header-height) + 1.2rem);
		display: grid;
		gap: 1.45rem;
		min-width: 0;
	}

	.home-left-rail,
	.next-reads {
		padding-top: 0.95rem;
		border-top: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
	}

	.section-heading {
		margin-bottom: 1rem;
	}

	.section-heading h2 {
		margin: 0;
		padding: 0;
		border: 0;
		font-size: 1.18rem;
	}

	.section-heading.compact {
		margin-bottom: 0.8rem;
	}

	.section-heading.with-link {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		border-bottom: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
		padding-bottom: 0.8rem;
	}

	.lead-layout {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 1rem;
		align-items: start;
	}

	.featured-story {
		display: block;
		overflow: hidden;
		border-radius: 8px;
		border: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
		text-decoration: none;
	}

	.featured-image {
		aspect-ratio: 1200 / 630;
		overflow: hidden;
	}

	.featured-image :global(img) {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
		border-radius: 0;
	}

	.featured-copy {
		padding-top: 0.2rem;
	}

	:global(.post-category-badge) {
		margin-bottom: 0.55rem;
	}

	.featured-copy h3 {
		margin: 0;
		font-size: 1.25rem;
		line-height: 1.55;
	}

	.featured-copy h3 a {
		color: var(--color-text-heading);
		text-decoration: none;
	}

	.featured-copy h3 a:hover {
		color: var(--color-primary-light);
		text-decoration: none;
	}

	.featured-copy p {
		margin: 0.65rem 0 0;
		color: var(--color-text-muted);
		font-size: 0.92rem;
		line-height: 1.8;
	}

	.featured-copy span {
		display: inline-block;
		margin-top: 0.65rem;
		color: var(--color-text-muted);
		font-size: 0.78rem;
	}

	.next-reads {
		margin: 0;
	}

	.next-list,
	.dispatch-list {
		display: grid;
		gap: 0;
	}

	.next-item,
	.dispatch-row {
		display: grid;
		gap: 0.3rem;
		padding: 0.9rem 0;
		border-top: 1px solid color-mix(in srgb, var(--color-border) 72%, transparent);
		text-decoration: none;
	}

	.next-item {
		grid-template-columns: 2ch minmax(0, 1fr);
		gap: 0.65rem;
	}

	.next-item:first-child,
	.dispatch-row:first-child {
		border-top: 0;
		padding-top: 0;
	}

	.next-rank,
	.dispatch-row span,
	.next-copy small {
		color: var(--color-text-muted);
		font-size: 0.75rem;
	}

	.next-copy {
		display: grid;
		gap: 0.25rem;
		min-width: 0;
	}

	.next-copy strong,
	.dispatch-row strong {
		color: var(--color-text-heading);
		font-size: 0.92rem;
		line-height: 1.55;
	}

	.next-item:hover .next-copy strong,
	.dispatch-row:hover strong {
		color: var(--color-primary-light);
	}

	.topic-list {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 0;
	}

	.topic-link {
		display: inline-flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		padding: 0.45rem 0;
		border-bottom: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
		color: var(--color-text-heading);
		font-size: 0.9rem;
		font-weight: 700;
		text-decoration: none;
	}

	.topic-link small {
		color: var(--color-text-muted);
		font-size: 0.72rem;
		font-weight: 600;
	}

	.topic-link:hover {
		color: var(--color-primary-light);
		text-decoration: none;
	}

	.dispatch-row {
		grid-template-columns: 7.5rem minmax(0, 1fr);
		align-items: baseline;
	}

	.rail-shortcuts {
		display: grid;
		gap: 0.45rem;
		padding-top: 0.95rem;
		border-top: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
	}

	.rail-shortcuts a {
		color: var(--color-text-heading);
		font-size: 0.86rem;
		font-weight: 700;
		text-decoration: none;
	}

	.rail-shortcuts a::after {
		content: ' ->';
		color: var(--home-accent);
	}

	.rail-shortcuts a:hover {
		color: var(--color-primary-light);
		text-decoration: none;
	}

	@media (max-width: 1100px) {
		.home-shell {
			grid-template-areas:
				'main'
				'left'
				'right';
			grid-template-columns: minmax(0, 1fr);
		}

		.home-left-rail,
		.home-right-rail {
			position: static;
		}

		.home-left-rail {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			align-items: start;
		}
	}

	@media (max-width: 768px) {
		main {
			width: var(--max-width);
			max-width: calc(100% - 2rem);
			padding: 1.5rem 1rem;
		}

		.radar-hero-grid,
		.lead-layout,
		.home-shell,
		.home-left-rail,
		.dispatch-row {
			grid-template-columns: 1fr;
		}

		.radar-actions {
			display: flex;
			flex-wrap: wrap;
		}

		.topic-list {
			grid-template-columns: 1fr;
		}
	}
</style>
