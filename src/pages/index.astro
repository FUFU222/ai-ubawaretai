---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import GenerativeHero from '../components/GenerativeHero.astro';
import Header from '../components/Header.astro';
import { HOME_PAGE_DESCRIPTION, HOME_PAGE_TITLE, SITE_TITLE } from '../consts';
import { organizationJsonLd, personJsonLd, websiteJsonLd } from '../utils/jsonld';
import { getPrimaryTag, getTagPath, getTagSummaries } from '../utils/tags';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);
const tagSummaries = getTagSummaries(allPosts)
	.filter((tag) => tag.isIndexable)
	.slice(0, 12);

const personLd = personJsonLd();
const organizationLd = organizationJsonLd();
const websiteLd = websiteJsonLd();
---

<!doctype html>
<html lang="ja">
		<head>
			<BaseHead title={HOME_PAGE_TITLE} description={HOME_PAGE_DESCRIPTION} />
			<script type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
			<script type="application/ld+json" set:html={JSON.stringify(personLd)} />
			<script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
		</head>
	<body>
		<Header />
		<div class="hero-banner">
			<img
				src="/header_image.webp"
				alt="AIに仕事を奪われたい - エンジニアがAIツールを使いこなすイラスト"
				width="1200"
				height="670"
				class="hero-banner-img"
				loading="eager"
			/>
		</div>
		<main>
			<section class="hero">
				<h1>{SITE_TITLE}</h1>
				<p class="hero-sub">
					AI業界の最新ニュースを
					<br class="hero-sub-break" />
					現役エンジニアの視点で読み解く
				</p>
				<p class="hero-lead">
					OpenAIやGoogleなどAI・ソフトウェア・プロダクトの更新を、日本の事業と開発の文脈で整理しています。
				</p>
				<div class="hero-actions">
					<a href="/blog" class="hero-action-primary">記事一覧を見る</a>
					<a href="/about" class="hero-action-secondary">このサイトについて</a>
				</div>
			</section>

			<section class="latest">
				<h2 class="section-title">最新の記事</h2>
				<div class="post-grid">
					{
						posts.map((post) => (
							<a href={`/blog/${post.id}/`} class="post-card">
								<div class="post-image">
									<GenerativeHero seed={post.data.title} alt={post.data.title} />
								</div>
								<div class="post-card-body">
									<CategoryBadge label={`#${getPrimaryTag(post.data.tags)}`} class="post-category-badge" />
									<h3 class="post-title">{post.data.title}</h3>
									<p class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</div>
							</a>
						))
					}
				</div>
				<div class="more-link">
					<a href="/blog">すべての記事を見る &rarr;</a>
				</div>
			</section>

			<section class="categories">
				<h2 class="section-title">タグ</h2>
				<div class="category-grid">
					{
						tagSummaries.map(({ slug, label, count }) => (
							<a href={getTagPath(slug)} class="category-card">
								<span>{label}</span>
								<span class="category-count">{count}件</span>
							</a>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		text-align: center;
		padding: 2rem 0;
	}

	.hero-banner {
		width: 100%;
		height: 200px;
		overflow: hidden;
	}

	.hero-banner-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 35%;
		display: block;
	}

	.hero h1 {
		font-size: 2rem;
		background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero-sub {
		color: var(--color-text-muted);
		font-size: 1rem;
		margin-top: 0.5rem;
	}

	.hero-lead {
		margin: 0.9rem auto 0;
		max-width: 42rem;
		font-size: 0.98rem;
		line-height: 1.8;
		color: var(--color-text-muted);
	}

	.hero-actions {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		margin-top: 1.15rem;
		flex-wrap: wrap;
	}

	.hero-actions a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 8.5rem;
		padding: 0.7rem 1rem;
		border-radius: 999px;
		font-size: 0.9rem;
		font-weight: 700;
		text-decoration: none;
	}

	.hero-action-primary {
		background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
		color: white;
	}

	.hero-action-secondary {
		background: color-mix(in srgb, var(--color-bg-card) 90%, transparent);
		border: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
		color: var(--color-text-heading);
	}

	.hero-sub-break {
		display: none;
	}

	.section-title {
		font-size: 1.25rem;
		margin-bottom: 1.25rem;
		padding-bottom: 0.4rem;
		border-bottom: 2px solid var(--color-border);
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.25rem;
	}

	.post-card {
		display: block;
		background-color: var(--color-bg-card);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		overflow: hidden;
		text-decoration: none;
		transition: border-color 0.2s, transform 0.2s;
	}

	.post-card:hover {
		border-color: var(--color-primary);
		transform: translateY(-2px);
		text-decoration: none;
	}

	.post-image {
		aspect-ratio: 1200 / 630;
		overflow: hidden;
	}

	.post-image :global(img) {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
		border-radius: 0;
	}

	.post-card-body {
		padding: 1rem;
	}

	:global(.post-category-badge) {
		margin-bottom: 0.5rem;
	}

	.post-title {
		font-size: 0.95rem;
		line-height: 1.5;
		color: var(--color-text-heading);
		margin-bottom: 0.4rem;
		border-bottom: none;
		padding-bottom: 0;
	}

	.post-date {
		font-size: 0.8rem;
		color: var(--color-text-muted);
		margin: 0;
	}

	.more-link {
		text-align: center;
		margin-top: 1.5rem;
	}

	.more-link a {
		color: var(--color-primary-light);
		font-size: 0.9rem;
	}

	.categories {
		margin-top: 3rem;
	}

	.category-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.75rem;
	}

	.category-card {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 1rem;
		background-color: var(--color-bg-card);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		color: var(--color-text-heading);
		font-weight: 600;
		font-size: 0.9rem;
		text-decoration: none;
		transition: border-color 0.2s;
	}

	.category-count {
		flex: none;
		font-size: 0.78rem;
		color: var(--color-text-muted);
	}

	.category-card:hover {
		border-color: var(--color-primary);
		text-decoration: none;
	}

	@media (max-width: 768px) {
		.post-grid {
			grid-template-columns: 1fr;
		}

		.category-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.hero h1 {
			font-size: 1.5rem;
		}

		.hero-sub-break {
			display: block;
		}
	}
</style>
