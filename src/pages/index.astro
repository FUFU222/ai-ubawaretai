---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import GenerativeHero from '../components/GenerativeHero.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { personJsonLd, websiteJsonLd } from '../utils/jsonld';
import { getPrimaryTag, getTagPath, getTagSummaries } from '../utils/tags';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);
const featuredPost = posts[0];
const nextPosts = posts.slice(1, 4);
const latestPosts = posts.slice(1, 6);
const tagSummaries = getTagSummaries(allPosts)
	.filter((tag) => tag.isIndexable)
	.slice(0, 12);

const personLd = personJsonLd();
const websiteLd = websiteJsonLd();
---

<!doctype html>
<html lang="ja">
		<head>
			<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
			<script type="application/ld+json" set:html={JSON.stringify(personLd)} />
			<script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
		</head>
	<body>
		<Header />
		<main>
			<section class="radar-hero">
				<p class="radar-kicker">AI News Radar</p>
				<div class="radar-hero-grid">
					<div>
						<h1>{SITE_TITLE}</h1>
						<p class="radar-lead">
							いま追うべきAIニュースを、日本の開発現場と事業判断に引き寄せて読む。
						</p>
					</div>
					<div class="radar-actions" aria-label="主要導線">
						<a href="/blog">最新記事を読む</a>
						<a href="/category">テーマで追う</a>
					</div>
				</div>
			</section>

			{
				featuredPost && (
					<section class="radar-board" aria-labelledby="first-read-title">
						<div class="section-heading">
							<p class="section-eyebrow">First Read</p>
							<h2 id="first-read-title">最初に読む</h2>
						</div>
						<div class="lead-layout">
							<a href={`/blog/${featuredPost.id}/`} class="featured-story">
								<div class="featured-image">
									<GenerativeHero seed={featuredPost.data.title} alt={featuredPost.data.title} />
								</div>
							</a>
							<div class="featured-copy">
								<CategoryBadge label={`#${getPrimaryTag(featuredPost.data.tags)}`} class="post-category-badge" />
								<h3>
									<a href={`/blog/${featuredPost.id}/`}>{featuredPost.data.title}</a>
								</h3>
								<p>{featuredPost.data.description}</p>
								<span>
									<FormattedDate date={featuredPost.data.pubDate} />
								</span>
							</div>
							<aside class="next-reads" aria-labelledby="next-reads-title">
								<div class="section-heading compact">
									<p class="section-eyebrow">Next Reads</p>
									<h2 id="next-reads-title">次に読む</h2>
								</div>
								<div class="next-list">
									{nextPosts.map((post) => (
										<a href={`/blog/${post.id}/`} class="next-item">
											<span>
												<FormattedDate date={post.data.pubDate} />
											</span>
											<strong>{post.data.title}</strong>
										</a>
									))}
								</div>
							</aside>
						</div>
					</section>
				)
			}

			<div class="home-secondary-grid">
				<section class="topic-radar">
					<div class="section-heading with-link">
						<div>
							<p class="section-eyebrow">Topics</p>
							<h2>注目テーマ</h2>
						</div>
						<a href="/category">すべてのタグ</a>
					</div>
					<div class="topic-list">
						{
							tagSummaries.map(({ slug, label, count }) => (
								<a href={getTagPath(slug)} class="topic-link">
									<span>{label}</span>
									<small>{count}件</small>
								</a>
							))
						}
					</div>
				</section>

				<section class="latest-dispatch">
					<div class="section-heading with-link">
						<div>
							<p class="section-eyebrow">Latest</p>
							<h2>最新</h2>
						</div>
						<a href="/blog">記事一覧へ</a>
					</div>
					<div class="dispatch-list">
						{
							latestPosts.map((post) => (
								<a href={`/blog/${post.id}/`} class="dispatch-row">
									<span>
										<FormattedDate date={post.data.pubDate} />
									</span>
									<strong>{post.data.title}</strong>
								</a>
							))
						}
					</div>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		--home-accent: #f59e0b;
		--home-desktop-width: 1280px;
		width: min(var(--home-desktop-width), calc(100% - 3rem));
		max-width: none;
		padding: 2.35rem 0;
	}

	.radar-hero {
		padding: 2rem 0 1.9rem;
		border-bottom: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
	}

	.radar-kicker,
	.section-eyebrow {
		margin: 0 0 0.45rem;
		color: var(--home-accent);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.radar-hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(12rem, auto);
		align-items: center;
		gap: 2rem;
	}

	.radar-hero h1 {
		margin: 0;
		font-size: clamp(1.7rem, 4vw, 2.35rem);
		letter-spacing: 0;
	}

	.radar-lead {
		max-width: 37rem;
		margin: 0.65rem 0 0;
		color: var(--color-text-muted);
		font-size: 0.98rem;
		line-height: 1.85;
	}

	.radar-actions {
		display: grid;
		gap: 0.55rem;
		min-width: 9rem;
	}

	.radar-actions a,
	.section-heading.with-link > a {
		color: var(--color-text-heading);
		font-size: 0.86rem;
		font-weight: 700;
		text-decoration: none;
	}

	.radar-actions a::after,
	.section-heading.with-link > a::after {
		content: ' ->';
		color: var(--home-accent);
	}

	.radar-board,
	.home-secondary-grid {
		margin-top: 2.25rem;
	}

	.section-heading {
		margin-bottom: 1rem;
	}

	.section-heading h2 {
		margin: 0;
		padding: 0;
		border: 0;
		font-size: 1.18rem;
	}

	.section-heading.compact {
		margin-bottom: 0.8rem;
	}

	.section-heading.with-link {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		border-bottom: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
		padding-bottom: 0.8rem;
	}

	.lead-layout {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(22rem, 0.85fr);
		gap: 1.35rem;
		align-items: start;
	}

	.featured-story {
		display: block;
		overflow: hidden;
		border-radius: 8px;
		border: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
		text-decoration: none;
	}

	.featured-image {
		aspect-ratio: 1200 / 630;
		overflow: hidden;
	}

	.featured-image :global(img) {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
		border-radius: 0;
	}

	.featured-copy {
		grid-column: 1;
		padding-top: 0.95rem;
	}

	:global(.post-category-badge) {
		margin-bottom: 0.55rem;
	}

	.featured-copy h3 {
		margin: 0;
		font-size: 1.25rem;
		line-height: 1.55;
	}

	.featured-copy h3 a {
		color: var(--color-text-heading);
		text-decoration: none;
	}

	.featured-copy h3 a:hover {
		color: var(--color-primary-light);
		text-decoration: none;
	}

	.featured-copy p {
		margin: 0.65rem 0 0;
		color: var(--color-text-muted);
		font-size: 0.92rem;
		line-height: 1.8;
	}

	.featured-copy span {
		display: inline-block;
		margin-top: 0.65rem;
		color: var(--color-text-muted);
		font-size: 0.78rem;
	}

	.next-reads {
		grid-column: 2;
		grid-row: 1 / span 2;
		padding: 1.15rem;
		border: 1px solid color-mix(in srgb, var(--color-border) 78%, transparent);
		border-radius: 8px;
		background: color-mix(in srgb, var(--color-bg-card) 70%, transparent);
	}

	.home-secondary-grid {
		display: grid;
		grid-template-columns: minmax(18rem, 0.72fr) minmax(0, 1.28fr);
		gap: 2rem;
		align-items: start;
	}

	.next-list,
	.dispatch-list {
		display: grid;
		gap: 0;
	}

	.next-item,
	.dispatch-row {
		display: grid;
		gap: 0.3rem;
		padding: 0.85rem 0;
		border-top: 1px solid color-mix(in srgb, var(--color-border) 72%, transparent);
		text-decoration: none;
	}

	.next-item:first-child,
	.dispatch-row:first-child {
		border-top: 0;
		padding-top: 0;
	}

	.next-item span,
	.dispatch-row span {
		color: var(--color-text-muted);
		font-size: 0.75rem;
	}

	.next-item strong,
	.dispatch-row strong {
		color: var(--color-text-heading);
		font-size: 0.92rem;
		line-height: 1.55;
	}

	.next-item:hover strong,
	.dispatch-row:hover strong {
		color: var(--color-primary-light);
	}

	.topic-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		column-gap: 1rem;
	}

	.topic-link {
		display: inline-flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		padding: 0.45rem 0;
		border-bottom: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
		color: var(--color-text-heading);
		font-size: 0.9rem;
		font-weight: 700;
		text-decoration: none;
	}

	.topic-link small {
		color: var(--color-text-muted);
		font-size: 0.72rem;
		font-weight: 600;
	}

	.topic-link:hover {
		color: var(--color-primary-light);
		text-decoration: none;
	}

	.dispatch-row {
		grid-template-columns: 7.5rem minmax(0, 1fr);
		align-items: baseline;
	}

	@media (max-width: 768px) {
		main {
			width: var(--max-width);
			max-width: calc(100% - 2rem);
			padding: 1.5rem 1rem;
		}

		.radar-hero-grid,
		.lead-layout,
		.home-secondary-grid,
		.dispatch-row {
			grid-template-columns: 1fr;
		}

		.radar-actions {
			display: flex;
			flex-wrap: wrap;
		}

		.next-reads {
			grid-column: auto;
			grid-row: auto;
		}

		.topic-list {
			grid-template-columns: 1fr;
		}
	}
</style>
