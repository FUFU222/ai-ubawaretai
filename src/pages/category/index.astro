---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getTagPath, getTagSummaries } from '../../utils/tags';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const tagSummaries = getTagSummaries(allPosts);
const featuredTags = tagSummaries.filter((tag) => tag.isIndexable);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`タグ | ${SITE_TITLE}`} description="企業名やテーマから記事を探せるタグ一覧ページ" />
	</head>
	<body>
		<Header />
		<main>
			<section class="category-hero">
				<p class="category-eyebrow">Topic Index</p>
				<h1>タグ</h1>
				<p class="category-lead">
					OpenAI や Anthropic のような企業名、半導体や音声AIのようなテーマ別に記事を探せます。
				</p>
			</section>

			{
				featuredTags.length === 0 ? (
					<p class="category-empty">表示できるタグがまだありません。</p>
				) : (
					<div class="topic-index">
						{
							featuredTags.map(({ slug, label, count }) => (
								<a href={getTagPath(slug)} class="topic-row">
									<span class="topic-name">{label}</span>
									<span class="topic-count">{count}件</span>
								</a>
							))
						}
					</div>
				)
			}

		</main>
		<Footer />
	</body>
</html>

<style>
	.category-hero {
		margin-bottom: 1.75rem;
		padding-bottom: 1.35rem;
		border-bottom: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
	}

	.category-eyebrow {
		margin: 0 0 0.45rem;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	h1 {
		margin-bottom: 0.6rem;
	}

	.category-lead {
		max-width: 42rem;
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.8;
	}

	.category-empty {
		color: var(--color-text-muted);
		padding: 2rem 0;
	}

	.topic-index {
		border-top: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
	}

	.topic-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem 0;
		border-bottom: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
		text-decoration: none;
		transition:
			border-color 0.18s ease,
			padding-left 0.18s ease,
			color 0.18s ease;
	}

	.topic-row:hover {
		padding-left: 0.35rem;
		border-color: color-mix(in srgb, #f59e0b 55%, var(--color-border));
		text-decoration: none;
	}

	.topic-name {
		font-size: 1.05rem;
		font-weight: 700;
		color: var(--color-text-heading);
	}

	.topic-count {
		flex: none;
		font-size: 0.8rem;
		font-weight: 700;
		color: #b45309;
	}

	@media (max-width: 768px) {
		.category-hero {
			margin-bottom: 1.4rem;
			padding-bottom: 1.1rem;
		}

		.topic-row {
			align-items: flex-start;
		}
	}
</style>
