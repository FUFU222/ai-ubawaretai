---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import PostThumbnail from '../../components/PostThumbnail.astro';
import { SITE_TITLE } from '../../consts';
import { getTagSummaries } from '../../utils/tags';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog', ({ data }) => !data.draft);
	const tagSummaries = getTagSummaries(allPosts);

	return tagSummaries
		.filter((summary) => summary.isIndexable)
		.map((summary) => ({
			params: { category: summary.slug },
			props: {
				posts: allPosts
					.filter((p) => p.data.tags.includes(summary.slug))
					.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
				tag: summary.label,
				tagSummary: summary,
			},
		}));
}

const { posts, tag } = Astro.props;
---

<!doctype html>
<html lang="ja">
		<head>
			<BaseHead
				title={`${tag} | ${SITE_TITLE}`}
				description={`${tag}に関する記事一覧ページです。公開済みの記事から関連トピックをまとめています。`}
			/>
		</head>
	<body>
		<Header />
		<main>
			<section class="topic-hero">
				<p class="topic-eyebrow">Topic Dispatch</p>
				<h1>{tag}</h1>
				<p class="topic-desc">タグ「{tag}」の記事一覧</p>
			</section>

			{
				posts.length === 0 ? (
					<p class="empty">まだ記事がありません。</p>
				) : (
					<ol class="topic-post-list">
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`} class="topic-post-row">
									<span class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</span>
									<PostThumbnail
										post={post}
										context="category-list"
										class="topic-post-thumb"
										width={176}
										height={99}
									/>
									<span class="post-info">
										<span class="post-title">{post.data.title}</span>
										<span class="post-desc">{post.data.description}</span>
									</span>
								</a>
							</li>
						))}
					</ol>
				)
			}

			<div class="back-link">
				<a href="/category">&larr; すべてのタグへ</a>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.topic-hero {
		margin-bottom: 1.75rem;
		padding-bottom: 1.35rem;
		border-bottom: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
	}

	.topic-eyebrow {
		margin: 0 0 0.45rem;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	h1 {
		margin-bottom: 0.55rem;
	}

	.topic-desc {
		color: var(--color-text-muted);
		font-size: 0.9rem;
		line-height: 1.8;
		margin: 0;
	}

	.empty {
		color: var(--color-text-muted);
		padding: 3rem 0;
	}

	.topic-post-list {
		list-style: none;
		margin: 0;
		padding: 0;
		border-top: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
	}

	.topic-post-row {
		display: grid;
		grid-template-columns: 7.5rem minmax(8.5rem, 10rem) minmax(0, 1fr);
		align-items: center;
		gap: 1.25rem;
		padding: 1.05rem 0;
		border-bottom: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
		text-decoration: none;
		transition:
			border-color 0.18s ease,
			padding-left 0.18s ease;
	}

	.topic-post-row:hover {
		padding-left: 0.35rem;
		border-color: color-mix(in srgb, #f59e0b 55%, var(--color-border));
		text-decoration: none;
	}

	.post-date {
		font-size: 0.78rem;
		font-weight: 700;
		color: #b45309;
	}

	.post-info {
		display: grid;
		gap: 0.35rem;
		min-width: 0;
	}

	.post-title {
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.55;
		color: var(--color-text-heading);
	}

	.post-desc {
		font-size: 0.86rem;
		line-height: 1.75;
		color: var(--color-text-muted);
	}

	.back-link {
		margin-top: 2rem;
	}

	.back-link a {
		color: var(--color-primary-light);
		font-size: 0.9rem;
	}

	@media (max-width: 768px) {
		.topic-hero {
			margin-bottom: 1.4rem;
			padding-bottom: 1.1rem;
		}

		.topic-post-row {
			grid-template-columns: 6.5rem minmax(0, 1fr);
			gap: 0.4rem 0.8rem;
			align-items: start;
		}

		.post-date {
			grid-column: 2;
			grid-row: 1;
		}

		:global(.topic-post-thumb) {
			grid-column: 1;
			grid-row: 1 / span 2;
			width: 100%;
		}

		.post-info {
			grid-column: 2;
			grid-row: 2;
		}
	}
</style>
