---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import GenerativeHero from '../../components/GenerativeHero.astro';
import Header from '../../components/Header.astro';
import { NOINDEX_ROBOTS, SITE_TITLE } from '../../consts';
import { getTagSummaries } from '../../utils/tags';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog', ({ data }) => !data.draft);
	const tagSummaries = getTagSummaries(allPosts);

	return tagSummaries.map((summary) => ({
		params: { category: summary.slug },
		props: {
			posts: allPosts
				.filter((p) => p.data.tags.includes(summary.slug))
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
			tag: summary.label,
			tagSummary: summary,
		},
	}));
}

const { posts, tag, tagSummary } = Astro.props;
const isIndexable = Boolean(tagSummary?.isIndexable);
---

<!doctype html>
<html lang="ja">
		<head>
			<BaseHead
				title={`${tag}の記事一覧 | ${SITE_TITLE}`}
				description={`${tag}に関する公開済みの記事一覧です。ニュース、使い方、比較、ワークフローの観点から関連トピックをまとめています。`}
				robots={isIndexable ? undefined : NOINDEX_ROBOTS}
			/>
		</head>
	<body>
		<Header />
		<main>
			<h1>{tag}</h1>
			<p class="category-desc">タグ「{tag}」の記事一覧</p>

			{
				posts.length === 0 ? (
					<p class="empty">まだ記事がありません。</p>
				) : (
					<div class="post-list">
						{posts.map((post) => (
							<a href={`/blog/${post.id}/`} class="post-item">
								<div class="post-thumb">
									<GenerativeHero seed={post.data.title} alt={post.data.title} />
								</div>
								<div class="post-info">
									<h2 class="post-title">{post.data.title}</h2>
									<p class="post-desc">{post.data.description}</p>
									<p class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</div>
							</a>
						))}
					</div>
				)
			}

			<div class="back-link">
				<a href="/category">&larr; すべてのタグへ</a>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		margin-bottom: 0.25rem;
	}

	.category-desc {
		color: var(--color-text-muted);
		font-size: 0.9rem;
		margin-bottom: 2rem;
	}

	.empty {
		color: var(--color-text-muted);
		text-align: center;
		padding: 3rem 0;
	}

	.post-list {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.post-item {
		display: grid;
		grid-template-columns: minmax(0, 240px) minmax(0, 1fr);
		align-items: start;
		gap: 1rem;
		background: color-mix(in srgb, var(--color-bg-card) 94%, transparent);
		border: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
		border-radius: 16px;
		padding: 1rem;
		text-decoration: none;
		transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
	}

	.post-item:hover {
		border-color: color-mix(in srgb, var(--color-primary) 48%, var(--color-border));
		transform: translateY(-2px);
		box-shadow: 0 16px 32px rgba(15, 23, 42, 0.08);
		text-decoration: none;
	}

	.post-thumb {
		aspect-ratio: 1200 / 630;
		overflow: hidden;
		border-radius: 10px;
	}

	.post-thumb :global(img) {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
		border-radius: 0;
	}

	.post-info {
		min-width: 0;
	}

	.post-title {
		font-size: 1.05rem;
		line-height: 1.4;
		color: var(--color-text-heading);
		margin: 0 0 0.25rem;
		border-bottom: none;
		padding-bottom: 0;
	}

	.post-desc {
		font-size: 0.85rem;
		color: var(--color-text-muted);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-date {
		font-size: 0.75rem;
		color: var(--color-text-muted);
		margin: 0.35rem 0 0;
	}

	.back-link {
		margin-top: 2rem;
	}

	.back-link a {
		color: var(--color-primary-light);
		font-size: 0.9rem;
	}

	@media (max-width: 768px) {
		.post-item {
			grid-template-columns: 1fr;
			gap: 0.85rem;
		}
	}
</style>
