---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import PostThumbnail from '../../components/PostThumbnail.astro';
import { SITE_TITLE } from '../../consts';
import { getSeriesPath, getSeriesSummaries, type SeriesSummary } from '../../utils/series';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog', ({ data }) => !data.draft);
	const summaries = getSeriesSummaries(allPosts);

	return summaries.map((summary) => ({
		params: { slug: summary.slug },
		props: { summary },
	}));
}

interface Props {
	summary: SeriesSummary;
}

const { summary } = Astro.props;
const description = summary.pillar?.data.description
	? `${summary.title}：${summary.pillar.data.description}`
	: `${summary.title}に関する連載記事のまとめ。全${summary.posts.length}記事を時系列で読めます。`;
const canonical = new URL(getSeriesPath(summary.slug), Astro.site).href;
---

<!doctype html>
<html lang="ja">
		<head>
			<BaseHead
				title={`${summary.title} | ${SITE_TITLE}`}
				description={description}
				canonical={canonical}
			/>
		</head>
	<body>
		<Header />
		<main>
			<nav class="breadcrumb" aria-label="パンくず">
				<a href="/">ホーム</a>
				<span aria-hidden="true">›</span>
				<a href="/blog/">ブログ</a>
				<span aria-hidden="true">›</span>
				<span aria-current="page">{summary.title}</span>
			</nav>

			<header class="series-hero">
				<p class="series-eyebrow">📚 シリーズ</p>
				<h1>{summary.title}</h1>
				<p class="series-meta">全{summary.posts.length}記事</p>
				{summary.pillar && (
					<p class="series-lead">{summary.pillar.data.description}</p>
				)}
			</header>

			{summary.pillar && (
				<section class="pillar-section" aria-labelledby="pillar-heading">
					<h2 id="pillar-heading">まずはこの記事から</h2>
					<a href={`/blog/${summary.pillar.id}/`} class="pillar-card">
						<PostThumbnail
							post={summary.pillar}
							context="series-pillar"
							class="pillar-thumb"
							width={320}
							height={168}
						/>
						<div class="pillar-info">
							<span class="pillar-badge">ピラー記事</span>
							<h3>{summary.pillar.data.title}</h3>
							<p>{summary.pillar.data.description}</p>
							<p class="pillar-date">
								<FormattedDate date={summary.pillar.data.pubDate} />
							</p>
						</div>
					</a>
				</section>
			)}

			<section class="series-list-section" aria-labelledby="series-list-heading">
				<h2 id="series-list-heading">全記事一覧</h2>
				<ol class="series-list">
					{summary.posts.map((post, index) => (
						<li class="series-list-item">
							<a href={`/blog/${post.id}/`} class="series-list-link">
								<span class="series-list-index">{String(index + 1).padStart(2, '0')}</span>
								<PostThumbnail
									post={post}
									context="series-list-page"
									class="series-list-thumb"
									width={200}
									height={105}
								/>
								<div class="series-list-info">
									{post.data.pillar && <span class="series-list-pillar-badge">ピラー</span>}
									<h3>{post.data.title}</h3>
									<p class="series-list-desc">{post.data.description}</p>
									<p class="series-list-date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</div>
							</a>
						</li>
					))}
				</ol>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: var(--max-width);
		max-width: calc(100% - 2rem);
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	.breadcrumb {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.85rem;
		color: var(--color-text-muted);
		margin-bottom: 1.25rem;
	}

	.breadcrumb a {
		color: var(--color-text-muted);
		text-decoration: none;
	}

	.breadcrumb a:hover {
		color: var(--color-primary-light, #60a5fa);
		text-decoration: underline;
	}

	.series-hero {
		margin-bottom: 2rem;
		padding: 1.5rem;
		border-radius: 16px;
		border: 1px solid color-mix(in srgb, var(--color-primary, #3b82f6) 30%, var(--color-border));
		background: color-mix(in srgb, var(--color-primary, #3b82f6) 6%, var(--color-bg-card));
	}

	.series-eyebrow {
		margin: 0 0 0.5rem;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	.series-hero h1 {
		font-size: 1.6rem;
		line-height: 1.3;
		margin: 0 0 0.5rem;
	}

	.series-meta {
		margin: 0 0 0.75rem;
		font-size: 0.85rem;
		color: var(--color-text-muted);
	}

	.series-lead {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.7;
		color: var(--color-text);
	}

	.pillar-section {
		margin-bottom: 3rem;
	}

	.pillar-section h2 {
		font-size: 1.1rem;
		margin-bottom: 1rem;
	}

	.pillar-card {
		display: grid;
		grid-template-columns: minmax(0, 320px) minmax(0, 1fr);
		gap: 1.25rem;
		padding: 1rem;
		border-radius: 14px;
		border: 1px solid var(--color-border);
		background: var(--color-bg-card);
		text-decoration: none;
		color: inherit;
		transition: border-color 0.2s, transform 0.2s;
	}

	.pillar-card:hover {
		transform: translateY(-2px);
		border-color: var(--color-primary-light, #60a5fa);
		text-decoration: none;
	}

	:global(.pillar-thumb) {
		aspect-ratio: 1200 / 630;
		border-radius: 10px;
	}

	.pillar-info {
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.pillar-badge {
		display: inline-flex;
		align-items: center;
		align-self: flex-start;
		padding: 0.18rem 0.6rem;
		border-radius: 999px;
		background: color-mix(in srgb, #f59e0b 22%, transparent);
		color: #d97706;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.04em;
	}

	.pillar-info h3 {
		font-size: 1.15rem;
		line-height: 1.4;
		margin: 0;
		color: var(--color-text-heading);
	}

	.pillar-info p {
		margin: 0;
		font-size: 0.9rem;
		line-height: 1.7;
		color: var(--color-text-muted);
	}

	.pillar-date {
		font-size: 0.8rem;
	}

	.series-list-section h2 {
		font-size: 1.1rem;
		margin-bottom: 1rem;
	}

	.series-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.series-list-link {
		display: grid;
		grid-template-columns: auto minmax(0, 200px) minmax(0, 1fr);
		align-items: center;
		gap: 1rem;
		padding: 0.85rem;
		border-radius: 12px;
		border: 1px solid var(--color-border);
		background: color-mix(in srgb, var(--color-bg-card) 92%, transparent);
		text-decoration: none;
		color: inherit;
		transition: border-color 0.2s, transform 0.2s;
	}

	.series-list-link:hover {
		transform: translateY(-1px);
		border-color: var(--color-primary-light, #60a5fa);
		text-decoration: none;
	}

	.series-list-index {
		font-size: 0.95rem;
		font-weight: 700;
		color: var(--color-text-muted);
		font-variant-numeric: tabular-nums;
		min-width: 2ch;
	}

	:global(.series-list-thumb) {
		aspect-ratio: 1200 / 630;
		border-radius: 8px;
	}

	.series-list-info {
		min-width: 0;
	}

	.series-list-pillar-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.12rem 0.45rem;
		border-radius: 999px;
		background: color-mix(in srgb, #f59e0b 22%, transparent);
		color: #d97706;
		font-size: 0.66rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		margin-bottom: 0.3rem;
	}

	.series-list-info h3 {
		font-size: 1rem;
		line-height: 1.4;
		margin: 0 0 0.3rem;
		color: var(--color-text-heading);
	}

	.series-list-desc {
		font-size: 0.85rem;
		line-height: 1.6;
		color: var(--color-text-muted);
		margin: 0 0 0.4rem;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.series-list-date {
		font-size: 0.75rem;
		color: var(--color-text-muted);
		margin: 0;
	}

	@media (max-width: 768px) {
		.pillar-card {
			grid-template-columns: 1fr;
		}

		.series-list-link {
			grid-template-columns: auto 5.8rem minmax(0, 1fr);
			gap: 0.7rem;
			align-items: start;
		}
	}
</style>
