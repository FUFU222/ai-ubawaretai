---
import { getCollection } from 'astro:content';
import BlogArchive from '../../components/BlogArchive.astro';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { BLOG_PAGE_SIZE, SITE_TITLE } from '../../consts';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const posts = allPosts.slice(0, BLOG_PAGE_SIZE);
const totalPages = Math.ceil(allPosts.length / BLOG_PAGE_SIZE);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title={`記事一覧 | ${SITE_TITLE}`}
			description="AI・ソフトウェア・プロダクトの更新を時系列で読める記事一覧です。OpenAI、Google、Anthropicなどのニュースと解説をまとめています。"
		/>
	</head>
	<body>
		<Header />
		<main>
			<BlogArchive
				posts={posts}
				currentPage={1}
				totalPages={totalPages}
				title="ブログ"
				description="公開済みの記事を時系列で一覧できます。企業名やテーマで横断したい場合はタグ一覧も使えます。"
			/>
		</main>
		<Footer />
	</body>
</html>
