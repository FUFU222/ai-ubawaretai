---
import { getCollection } from 'astro:content';
import BlogArchive from '../../../components/BlogArchive.astro';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import { BLOG_PAGE_SIZE, NOINDEX_ROBOTS, SITE_DESCRIPTION, SITE_TITLE } from '../../../consts';

export async function getStaticPaths() {
	const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);
	const totalPages = Math.ceil(allPosts.length / BLOG_PAGE_SIZE);

	return Array.from({ length: Math.max(totalPages - 1, 0) }, (_, index) => {
		const currentPage = index + 2;
		const start = (currentPage - 1) * BLOG_PAGE_SIZE;
		const end = start + BLOG_PAGE_SIZE;

		return {
			params: { page: String(currentPage) },
			props: {
				posts: allPosts.slice(start, end),
				currentPage,
				totalPages,
			},
		};
	});
}

const { posts, currentPage, totalPages } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
			<BaseHead
				title={`ブログ ${currentPage}ページ目 | ${SITE_TITLE}`}
				description={SITE_DESCRIPTION}
				robots={NOINDEX_ROBOTS}
			/>
	</head>
	<body>
		<Header />
		<main>
			<BlogArchive
				posts={posts}
				currentPage={currentPage}
				totalPages={totalPages}
				title="ブログ"
				description="公開済みの記事を時系列で一覧できます。企業名やテーマで横断したい場合はタグ一覧も使えます。"
			/>
		</main>
		<Footer />
	</body>
</html>
