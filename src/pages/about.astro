---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { GITHUB_URL, SITE_AUTHOR, SITE_AUTHOR_DESCRIPTION, SITE_TITLE } from '../consts';
import { personJsonLd } from '../utils/jsonld';

const personLd = personJsonLd();
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description={SITE_AUTHOR_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify(personLd)} />
	</head>
	<body>
		<Header />
		<main>
			<article class="about">
				<h1>About</h1>

				<section>
					<h2>運営者</h2>
					<p class="author-name">{SITE_AUTHOR}</p>
					<p>{SITE_AUTHOR_DESCRIPTION}</p>
				</section>

				<section>
					<h2>経歴</h2>
					<ul class="career">
						<li>消防士（レスキュー隊）として現場で活動</li>
						<li>エンジニアに転身、SNSマーケ会社でフルスタック開発</li>
							<li>セミナー10回以上開催（累計300人以上）</li>
					</ul>
				</section>

				<section>
					<h2>このブログについて</h2>
					<p>
						「AIに仕事を奪われたい」は、AIツールの新着情報を公開するたびに「ヤバい！」と驚いている方々を尻目に、実際に著者が使い倒した上で、実務者の視点から、
						本当に使えるツールとその活用法を発信するブログです。
					</p>
					</section>

				<section>
					<h2>使用ツール</h2>
					<ul>
						<li>Claude Code / Claude</li>
						<li>OpenAI Codex / ChatGPT</li>
						<li>GitHub Copilot</li>
						<li>Cursor</li>
						<li>v0</li>
					</ul>
				</section>

				<section>
					<h2>リンク</h2>
					<ul>
						<li><a href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a></li>
					</ul>
				</section>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.about h2 {
		font-size: 1.25rem;
		margin-top: 2rem;
	}

	.author-name {
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--color-text-heading);
		margin-bottom: 0.5rem;
	}

	.career li {
		margin-bottom: 0.5rem;
	}

	ul {
		padding-left: 1.5em;
	}
</style>
